#!/usr/bin/env python3
"""claude-sessions — vue terminal des sessions Claude Code du jour.

Lit ~/.claude/projects/**/*.jsonl, ne garde que les transcripts modifiés
aujourd'hui. Affiche project / status / title / last activity / model / prompt.
LAST = temps écoulé depuis la dernière interaction (pas l'âge de la session).

Statut (flags explicites prioritaires, sinon heuristique de fraîcheur) :
  ‖ paused       — mis en veille manuellement (survit au prune)
  ◑ knocking     — Claude attend une réponse (hook « Knock knock », fiable)
  ● in the matrix — Claude travaille : tour en cours (hook UserPromptSubmit→Stop,
                   fiable), outil/subagent en cours, ou activité transcript récente
  ● jacked in    — session ouverte/attachée (process vivant, sans activité récente)
  ○ unplugged    — plus d'activité depuis un moment

Options :
  (défaut)        live, redessiné toutes les 60 s ; 3 niveaux cyclés par Tab
  --once / -1     snapshot puis rend la main
  --all  / -a     démarre au niveau complet (inclut les sessions de fond)
  --full / -f     démarre au niveau complet (colonnes tokens/coût)
  --interval N    intervalle de rafraîchissement en s (défaut 10)
  --ctx-max N     seuil pour la couleur de CTX (défaut 200000)

Touches (mode live) :
  ↑↓ / j k        naviguer ; PgUp/PgDn page ; g/G haut/bas
  ⏎               focus la fenêtre kitty de l'agent (sinon reprise dans une nouvelle)
  n / [💊 Red Pill]  ouvre le sélecteur redpill dans une nouvelle fenêtre kitty
                  (touche n, ou clic sur le bouton [💊 Red Pill] de l'en-tête)
  z               (dé)marquer la session sélectionnée en veille (paused)
  w               réveiller la session sélectionnée (focus / rouvre)
  W / [⏰ Wake Up Neo]  réveiller TOUTES les sessions en pause
  d               ouvrir le détail de la session (métadonnées + tours)
  e               quitter proprement la session (/exit) puis fermer la fenêtre kitty
  Esc             revenir à la liste (depuis le détail)
  /               filtrer la liste (projet / titre / prompt) ; Esc efface
  Ctrl+K          fermer la session : tue le process (SIGTERM) après confirmation
  Tab             cycle de niveau : normal → étendu (+unplugged) → complet (+bg)
  s               changer le tri (activité / contexte / tokens)
  p               pause/reprise du refresh ; F5 : refresh immédiat (r : alias)
  q               quitter

Niveaux : normal = jacked in / in construct / paused / knocking ; étendu ajoute
les unplugged ; complet ajoute les sessions de fond + colonnes CTX / OUT / COST /
HOST / MODEL. Statut `● jacked in` = process vivant détecté ; sinon heuristique.
"""
import glob
import json
import os
import select
import signal
import shutil
import subprocess
import sys
import termios
import time
import unicodedata
import tty

sys.path.insert(0, os.path.dirname(os.path.abspath(__file__)))
import matrix_logo as logo

PROJECTS = os.path.expanduser("~/.claude/projects")

ACTIVE_MAX = 15       # s : en dessous → actif
WAITING_MAX = 300     # s : en dessous → en attente, au delà → inactif
RESPONDING_MAX = 600  # s : dernier message = user (prompt) → considéré actif

# Couleurs ANSI (activées seulement si sortie = terminal)
USE_COLOR = sys.stdout.isatty()


def c(code, text):
    return ("\033[%sm%s\033[0m" % (code, text)) if USE_COLOR else text


# Palette inspirée du thème k9s par défaut (codes 256 couleurs).
T_LOGO = "1;38;5;46"           # titre principal — vert Matrix
T_BORDER = "38;5;33"           # bordures du cadre — dodgerblue
T_TITLE = "1;38;5;51"          # titre du cadre "Sessions[n]" — aqua
T_LBL = "38;5;117"             # libellés info / clés — bleu clair
T_VAL = "38;5;231"             # valeurs — blanc
T_KEY = "1;38;5;33"            # touches de raccourci — dodgerblue
T_DESC = "38;5;250"            # description de raccourci — gris clair
T_HDR = "1;38;5;51"            # en-têtes de colonnes — aqua
T_ACTIVE = "1;38;5;42"         # option active / statut actif — vert
T_DIM = "38;5;244"             # texte secondaire / idle — gris
T_GREEN = "38;5;42"
T_YELLOW = "38;5;214"
T_RED = "38;5;197"
T_STANDBY = "38;5;110"         # tour terminé, au repos — bleu-gris
T_SELECT = "48;5;236"          # ligne sélectionnée — bande gris foncé discrète (préserve les couleurs)
T_BTN = "1;38;5;16;48;5;46"    # boutons — noir gras sur fond vert Matrix


def start_of_today():
    lt = time.localtime()
    return time.mktime((lt.tm_year, lt.tm_mon, lt.tm_mday, 0, 0, 0, 0, 0, -1))


# Tarifs $ par million de tokens (input, output) — cache read ≈ 0,1×, write ≈ 1,25×.
MODEL_PRICES = {"fable": (10, 50), "mythos": (10, 50),
                "opus": (5, 25), "sonnet": (3, 15), "haiku": (1, 5)}


def model_prices(model):
    m = (model or "").lower()
    for key, prices in MODEL_PRICES.items():
        if key in m:
            return prices
    return (5, 25)  # défaut tarif Opus


def session_cost(inp, cache_read, cache_creation, out, model):
    """Coût estimé de la session en $ (heuristique : tarifs publics × tokens cumulés)."""
    pin, pout = model_prices(model)
    return ((inp * pin) + (cache_creation * pin * 1.25)
            + (cache_read * pin * 0.1) + (out * pout)) / 1_000_000


def fmt_cost(v):
    if v is None:
        return "—"
    if v < 0.01:
        return "<$.01"
    return "$%.2f" % v


def model_color(model):
    """Couleur par famille de modèle, pour le repérage visuel."""
    m = (model or "").lower()
    if "fable" in m or "mythos" in m:
        return "1;38;5;208"   # orange vif
    if "opus" in m:
        return "38;5;170"     # magenta
    if "sonnet" in m:
        return "38;5;75"      # bleu
    if "haiku" in m:
        return "38;5;78"      # vert
    return T_VAL


# Cache de parsing par transcript, invalidé au changement de mtime : une session
# inchangée n'est jamais relue. path -> {mtime, size, data, with_tokens}.
_PARSE_CACHE = {}

# Champs recalculés depuis la QUEUE du transcript à chaque changement (le dernier
# message et les métadonnées de tour vivent en fin de fichier). Le reste (started,
# entrypoint, background, is_agent, title/ai-title) est immuable ou stable : établi
# au 1er parse complet, puis conservé.
_RECENT_FIELDS = ("cwd", "branch", "last_msg_type", "working", "asks",
                  "last_prompt", "custom_name", "model")


_QUESTION_CUES = ("veux-tu", "souhaites-tu", "dois-je", "faut-il", "préfères-tu",
                  "tu veux que je", "dis-moi si", "should i", "do you want",
                  "would you like", "let me know")


def _looks_like_question(text):
    """Heuristique (A1) : le dernier message assistant se termine-t-il par une
    question ? Signal principal = point d'interrogation final (après strip du
    markdown de fin) ; à défaut, quelques tournures d'invite fréquentes sur la
    dernière ligne. Volontairement approximatif — l'état 'maybe-asking' assume
    cette incertitude, à la différence du 'knocking' issu des hooks."""
    if not text:
        return False
    tail = text.rstrip().rstrip("*_`\"')]}").rstrip()
    if not tail:
        return False
    if tail.endswith("?"):
        return True
    last_line = tail.splitlines()[-1].lower()
    return any(cue in last_line for cue in _QUESTION_CUES)


def _scan_reversed(lines, with_tokens):
    """Champs 'récents' + cumul tokens, par parcours à rebours (1re occurrence =
    la plus récente). Réducteur PARTAGÉ par le parse complet et le parse par queue :
    sur un même jeu de lignes il produit un résultat identique — c'est ce qui
    garantit que lire la queue équivaut à lire tout le fichier pour ces champs."""
    ai_title = None
    custom_name = None
    last_prompt = None
    cwd = None
    git_branch = None
    last_msg_type = None
    working = None  # dernier message = tool_use assistant en cours (outil/subagent)
    asks = None  # dernier message = assistant terminant sur une question (heuristique)
    is_agent = False
    context_tokens = None
    output_total = 0
    input_total = 0
    cache_read_total = 0
    cache_creation_total = 0
    model = None

    for line in reversed(lines):
        if not is_agent and '"agent-setting"' in line:
            is_agent = True
        if ai_title is None and '"ai-title"' in line:
            try:
                ai_title = json.loads(line).get("aiTitle")
            except Exception:
                pass
        if custom_name is None and '"agent-name"' in line:
            try:
                custom_name = json.loads(line).get("agentName")
            except Exception:
                pass
        if last_prompt is None and '"last-prompt"' in line:
            try:
                last_prompt = json.loads(line).get("lastPrompt")
            except Exception:
                pass
        is_asst = '"assistant"' in line
        is_msg = is_asst or '"user"' in line
        # Dernier message (1er en reverse) : un tool_use assistant non suivi d'un
        # résultat = un outil/subagent tourne → session « au travail » même si le
        # transcript n'a pas bougé (cas du subagent, du long Bash…).
        if working is None and is_msg:
            try:
                _o = json.loads(line)
            except Exception:
                _o = None
            if _o is not None:
                _content = (_o.get("message") or {}).get("content")
                _is_asst = _o.get("type") == "assistant" and isinstance(_content, list)
                working = (_is_asst
                           and any(isinstance(b, dict) and b.get("type") == "tool_use"
                                   for b in _content))
                # Question en attente : un assistant qui ne lance PAS d'outil et dont
                # le dernier bloc texte ressemble à une question (sinon un tour finit
                # sur un tool_use → c'est du travail, pas une attente de réponse).
                _texts = ([b.get("text", "") for b in _content
                           if isinstance(b, dict) and b.get("type") == "text"]
                          if _is_asst else [])
                asks = bool(_is_asst and not working and _texts
                            and _looks_like_question(_texts[-1]))
        # On parse une ligne message si : cwd manquant, modèle manquant (assistant),
        # ou mode tokens (tous les assistants, pour le cumul).
        if is_msg and (cwd is None or (is_asst and (model is None or with_tokens))):
            try:
                obj = json.loads(line)
            except Exception:
                continue
            t = obj.get("type")
            msg = obj.get("message") or {}
            if t in ("assistant", "user") and cwd is None:
                cwd = obj.get("cwd")
                git_branch = obj.get("gitBranch")
                if last_msg_type is None:
                    last_msg_type = t
            if t == "assistant":
                if model is None:  # 1er en reverse = dernier message
                    model = msg.get("model")
                if with_tokens:
                    u = msg.get("usage") or {}
                    output_total += u.get("output_tokens") or 0
                    input_total += u.get("input_tokens") or 0
                    cache_read_total += u.get("cache_read_input_tokens") or 0
                    cache_creation_total += u.get("cache_creation_input_tokens") or 0
                    if context_tokens is None:
                        context_tokens = ((u.get("input_tokens") or 0)
                                          + (u.get("cache_read_input_tokens") or 0)
                                          + (u.get("cache_creation_input_tokens") or 0))
    return {
        "cwd": cwd, "branch": git_branch, "last_msg_type": last_msg_type,
        "working": bool(working), "asks": bool(asks),
        "last_prompt": (last_prompt or "").replace("\n", " ").strip(),
        "custom_name": custom_name, "model": model,
        "ai_title": ai_title, "is_agent": is_agent,
        "context_tokens": context_tokens, "output_total": output_total,
        "input_total": input_total, "cache_read_total": cache_read_total,
        "cache_creation_total": cache_creation_total,
    }


def _scan_forward(lines):
    """Ouverture de la session (scan rapide du début, immuable) : 1er timestamp =
    création, entrypoint du 1er message = mode de LANCEMENT réel (cli/vscode/sdk-cli).
    On se fie à l'ouverture, pas au dernier tour : sinon un `claude -p`/resume en mode
    print (sdk-cli) reclasserait toute une session interactive en background."""
    started = None
    entrypoint = None
    for line in lines:
        if started is None and '"timestamp"' in line:
            try:
                started = parse_ts(json.loads(line).get("timestamp"))
            except Exception:
                started = None
        if entrypoint is None and '"entrypoint"' in line and (
                '"user"' in line or '"assistant"' in line):
            try:
                entrypoint = json.loads(line).get("entrypoint")
            except Exception:
                entrypoint = None
        if started is not None and entrypoint is not None:
            break
    return started, entrypoint


def _assemble(path, rev, started, entrypoint, with_tokens):
    """Assemble le dict de session final à partir des champs récents (`rev`) et
    des champs d'ouverture (`started`, `entrypoint`)."""
    sid = os.path.basename(path)[:-6]  # retire .jsonl
    project = os.path.basename((rev["cwd"] or os.path.dirname(path)).rstrip("/"))
    title = rev["ai_title"] or ("session " + sid[:8])
    try:
        mtime = os.path.getmtime(path)
    except Exception:
        mtime = 0
    background = rev["is_agent"] or (entrypoint == "sdk-cli")
    cost = (session_cost(rev["input_total"], rev["cache_read_total"],
                         rev["cache_creation_total"], rev["output_total"], rev["model"])
            if with_tokens else None)
    return {
        "sid": sid, "path": path, "started": started, "background": background,
        "cwd": rev["cwd"], "project": project, "branch": rev["branch"], "title": title,
        "last_prompt": rev["last_prompt"], "last_msg_type": rev["last_msg_type"],
        "working": rev["working"], "asks": rev["asks"], "is_agent": rev["is_agent"],
        "entrypoint": entrypoint, "custom_name": rev["custom_name"], "mtime": mtime,
        "context_tokens": rev["context_tokens"], "output_total": rev["output_total"],
        "cost": cost, "model": rev["model"],
    }


def _read_all_lines(path):
    try:
        with open(path) as f:
            return f.readlines()
    except Exception:
        return None


def _read_tail_lines(path, want_bytes):
    """Dernières ~want_bytes du fichier, en lignes. Jette la 1re ligne si la fenêtre
    ne part pas du début (elle peut être tronquée). None si illisible."""
    try:
        with open(path, "rb") as f:
            f.seek(0, 2)
            size = f.tell()
            start = max(0, size - want_bytes)
            f.seek(start)
            data = f.read()
    except Exception:
        return None
    lines = data.decode("utf-8", "replace").splitlines()
    if start > 0 and lines:
        lines = lines[1:]
    return lines


def _parse_full(path, with_tokens=False):
    """Parse complet (lecture intégrale) — sert au 1er affichage d'une session et
    au mode --full. Établit tous les champs, immuables compris."""
    lines = _read_all_lines(path)
    if lines is None:
        return None
    rev = _scan_reversed(lines, with_tokens)
    started, entrypoint = _scan_forward(lines)
    return _assemble(path, rev, started, entrypoint, with_tokens)


def _parse_tail_update(path, prev):
    """Rafraîchit les seuls champs récents depuis la queue du transcript, en gardant
    les immuables et le titre de `prev`. Agrandit la fenêtre jusqu'à retrouver
    last-prompt (ou avoir lu tout le fichier), sinon conserve l'ancien last_prompt."""
    try:
        size = os.path.getsize(path)
    except OSError:
        return prev
    lines = None
    for want in (64_000, 256_000, 1_000_000, 4_000_000):
        lines = _read_tail_lines(path, want)
        if lines is None:
            return prev
        if any('"last-prompt"' in l for l in lines) or want >= size:
            break
    rev = _scan_reversed(lines, False)
    data = dict(prev)
    for k in _RECENT_FIELDS:
        data[k] = rev[k]
    if not rev["last_prompt"] and prev.get("last_prompt"):
        data["last_prompt"] = prev["last_prompt"]  # filet : queue trop courte
    data["project"] = os.path.basename((rev["cwd"] or os.path.dirname(path)).rstrip("/"))
    try:
        data["mtime"] = os.path.getmtime(path)
    except Exception:
        pass
    return data


def parse_session(path, with_tokens=False):
    """Dict décrivant la session (ou None), avec cache par mtime.

    Session inchangée → renvoyée du cache (0 lecture). Au changement : en mode
    normal, seule la QUEUE est relue (champs récents) ; les immuables et le titre
    sont conservés du 1er parse complet. En mode --full (tokens), reparse complet,
    lui aussi mis en cache par mtime."""
    try:
        st = os.stat(path)
    except OSError:
        return None
    mtime, size = st.st_mtime, st.st_size

    c = _PARSE_CACHE.get(path)
    if c and c["mtime"] == mtime and c["with_tokens"] >= with_tokens:
        return c["data"]

    # Reparse complet : 1re rencontre, mode --full, ou fichier tronqué/compacté.
    if c is None or with_tokens or size < c["size"]:
        data = _parse_full(path, with_tokens)
        if data is not None:
            _PARSE_CACHE[path] = {"mtime": mtime, "size": size,
                                  "data": data, "with_tokens": with_tokens}
        return data

    # Mode normal, session déjà connue qui a bougé : relire seulement la queue.
    data = _parse_tail_update(path, c["data"])
    _PARSE_CACHE[path] = {"mtime": mtime, "size": size,
                          "data": data, "with_tokens": False}
    return data


def claude_procs():
    """Process `claude` vivants : dicts {pid, cwd, resume_id, entrypoint, started}.
    Retourne None si /proc est inaccessible. Sert au statut `live` (lien FIABLE via
    --resume) et à la fermeture (identification du process par cwd, faute de mieux :
    le session id n'apparaît ni dans la cmdline, ni dans l'environ, ni en fd ouvert)."""
    try:
        pids = [p for p in os.listdir("/proc") if p.isdigit()]
    except Exception:
        return None
    procs = []
    for pid in pids:
        try:
            with open("/proc/%s/cmdline" % pid, "rb") as f:
                argv = [a.decode("utf-8", "ignore") for a in f.read().split(b"\0") if a]
        except Exception:
            continue
        if not argv or os.path.basename(argv[0]) != "claude":
            continue
        resume_id = None  # sid porté par ce process (repris OU nouvelle session)
        for flag in ("--resume", "--session-id"):
            if flag in argv:
                try:
                    resume_id = argv[argv.index(flag) + 1]
                    break
                except (ValueError, IndexError):
                    pass
        try:
            cwd = os.readlink("/proc/%s/cwd" % pid)
        except Exception:
            cwd = None
        entrypoint = None
        try:
            with open("/proc/%s/environ" % pid, "rb") as f:
                for kv_ in f.read().split(b"\0"):
                    if kv_.startswith(b"CLAUDE_CODE_ENTRYPOINT="):
                        entrypoint = kv_.split(b"=", 1)[1].decode("utf-8", "ignore")
                        break
        except Exception:
            pass
        try:
            started = os.stat("/proc/%s" % pid).st_ctime
        except Exception:
            started = None
        procs.append({"pid": int(pid), "cwd": cwd, "resume_id": resume_id,
                      "entrypoint": entrypoint, "started": started})
    return procs


def kill_candidates(sess, procs):
    """Process candidats pour fermer `sess`. Lien fiable d'abord (process repris avec
    ce sid exact), sinon match par cwd (ambigu si plusieurs sessions au même dossier)."""
    if procs is None:
        return None
    exact = [p for p in procs if p.get("resume_id") == sess.get("sid")]
    if exact:
        return exact
    cwd = sess.get("cwd")
    if not cwd:
        return []
    return [p for p in procs if p.get("cwd") == cwd]


STATUS_META = {  # état → (couleur, libellé thème Matrix) — glyphes mono-cellule
    "paused": (T_LBL, "‖ paused"),      # flag manuel (veille)
    "knocking": (T_YELLOW, "◑ knocking"),  # flag waiting (AskUserQuestion / permission)
    "maybe_asking": (T_YELLOW, "◔ maybe-asking"),  # done + question texte libre (heuristique)
    "live": (T_ACTIVE, "● jacked in"),
    "active": (T_ACTIVE, "● in the matrix"),
    "standby": (T_STANDBY, "◇ standby"),  # flag done : tour terminé, au repos
    "idle": (T_DIM, "○ unplugged"),
}


def status_kind(sess, now):
    """État de la session + âge depuis mtime. Les flags explicites priment :
    paused (manuel), knocking (waiting : AskUserQuestion/permission), puis
    l'activité réelle (busy/working/prompt), puis maybe_asking (done mais le
    dernier message finit sur une question — heuristique), standby (done : tour
    terminé), enfin la liveness/âge (live, sinon unplugged)."""
    age = now - sess["mtime"]
    if sess.get("paused"):
        return "paused", age
    if sess.get("waiting"):
        return "knocking", age
    if sess.get("busy") and sess.get("live"):
        return "active", age    # tour en cours (hook UserPromptSubmit→Stop, fiable)
    if sess.get("working"):
        return "active", age    # fallback : outil/subagent en cours (dernier msg = tool_use)
    if sess["last_msg_type"] == "user" and age < RESPONDING_MAX:
        return "active", age    # prompt envoyé, Claude travaille dessus
    if (sess.get("done") and sess.get("live") and sess.get("asks")
            and not sess.get("asking_dismissed")):
        return "maybe_asking", age  # Stop reçu mais le dernier message finit sur une question
    if sess.get("done") and sess.get("live"):
        return "standby", age   # Stop reçu, rien en cours, terminal encore ouvert
    if age < ACTIVE_MAX:
        return "active", age    # activité transcript très récente
    if sess.get("live"):  # process vivant (--resume/--session-id) mais pas d'activité récente
        return "live", age
    return "idle", age


def status(sess, now):
    kind, age = status_kind(sess, now)
    code, label = STATUS_META[kind]
    return c(code, label), age


HOST_META = {"vscode": ("38;5;75", "vscode"), "kitty": (T_GREEN, "kitty"), "bg": (T_DIM, "bg")}


def host_cell(sess):
    """Hôte de la session (kitty / vscode / bg) déduit de l'entrypoint du transcript."""
    ep = sess.get("entrypoint") or ""
    if "vscode" in ep:
        key = "vscode"
    elif ep == "sdk-cli":
        key = "bg"
    elif ep == "cli":
        key = "kitty"
    else:
        key = None
    if key:
        code, text = HOST_META[key]
        return c(code, text)
    return c(T_DIM, ep or "—")


def drop_idle(sessions, hide):
    """Filtre les sessions inactives si `hide` est vrai (recalculé sur l'instant courant)."""
    if not hide:
        return sessions
    now = time.time()
    return [s for s in sessions if status_kind(s, now)[0] != "idle"]


def fmt_age(age):
    age = int(age)
    if age < 60:
        return "%ds" % age
    if age < 3600:
        return "%dm" % (age // 60)
    if age < 86400:
        return "%dh" % (age // 3600)
    return "%dd" % (age // 86400)


def fmt_tokens(n):
    if not n:
        return "—" if n is None else "0"
    if n < 1000:
        return str(n)
    if n < 1_000_000:
        return "%.0fk" % (n / 1000)
    return "%.1fM" % (n / 1_000_000)


def short_model(m):
    return m.replace("claude-", "") if m else "—"


def trunc(s, n):
    s = s or ""
    return s if len(s) <= n else s[: n - 1] + "…"


def visible_len(s):
    """Largeur d'affichage en cellules, ANSI ignoré. Les glyphes est-asiatiques
    « larges » (W/F) — dont les emoji 💊/⏰ — comptent pour 2 ; les combinants 0."""
    out, i = 0, 0
    while i < len(s):
        if s[i] == "\033":
            while i < len(s) and s[i] != "m":
                i += 1
            i += 1
        else:
            ch = s[i]
            if not unicodedata.combining(ch):
                out += 2 if unicodedata.east_asian_width(ch) in ("W", "F") else 1
            i += 1
    return out


def pad(s, n):
    return s + " " * max(0, n - visible_len(s))


def title_cell(s, width):
    """Cellule TITLE : « /rename · ai-title » (rename en clair, ai-title en gris)
    quand un vrai /rename existe ; sinon juste l'ai-title."""
    ai = s.get("title") or ""
    cn = s.get("custom_name")
    if not cn:
        return trunc(ai, width)
    full = trunc(cn + " · " + ai, width)
    if full.startswith(cn):
        return c(T_VAL, cn) + c(T_DIM, full[len(cn):])
    return c(T_VAL, full)


def matrix_state():
    """Map session_id -> entrée Matrix (agent, fenêtre/socket kitty). {} si indispo."""
    try:
        import matrix_lib
        return matrix_lib.all_sessions()
    except Exception:
        return {}


def matrix_personas():
    """Ensemble des noms du pool Matrix (pour distinguer un vrai /rename du persona)."""
    try:
        import matrix_lib
        return set((matrix_lib.load_config() or {}).get("personas") or [])
    except Exception:
        return set()


def collect(include_agents, with_tokens=False):
    cutoff = start_of_today()
    procs = claude_procs()  # process claude vivants (statut live + fermeture)
    resume_ids = (set(p["resume_id"] for p in procs if p.get("resume_id"))
                  if procs is not None else None)
    sessions = []
    for path in glob.glob(os.path.join(PROJECTS, "*", "*.jsonl")):
        try:
            if os.path.getmtime(path) < cutoff:
                continue
        except Exception:
            continue
        s = parse_session(path, with_tokens=with_tokens)
        if not s:
            continue
        if s["background"] and not include_agents:
            continue
        s["live"] = bool(resume_ids and s["sid"] in resume_ids)
        sessions.append(s)

    import matrix_lib
    seen = {s["sid"] for s in sessions}
    for p in matrix_lib.paused_sessions():
        if p["sid"] in seen:
            continue
        path = matrix_lib.find_transcript(p["sid"])
        s = parse_session(path, with_tokens=with_tokens) if path else None
        if s is None:
            # transcript gone: synthesize a minimal row with SAFE defaults for
            # every key render()/status()/title_cell() reads.
            s = {
                "sid": p["sid"], "path": path, "started": p.get("since"),
                "background": False, "cwd": p.get("cwd"),
                "project": p.get("project") or "?", "branch": None,
                "title": p.get("label") or ("session " + p["sid"][:8]),
                "last_prompt": "", "last_msg_type": None, "is_agent": False,
                "entrypoint": None, "custom_name": None,
                "mtime": p.get("since") or 0, "context_tokens": None,
                "output_total": 0, "cost": None, "model": None,
            }
        if s.get("background") and not include_agents:
            continue
        s["live"] = bool(resume_ids and s["sid"] in resume_ids)
        sessions.append(s)

    mx = matrix_state()
    pool = matrix_personas()
    for s in sessions:
        e = mx.get(s["sid"]) or {}
        s["agent"] = e.get("agent")
        s["mx_window"] = e.get("kitty_window_id")
        s["mx_socket"] = e.get("kitty_listen_on")
        s["paused"] = e.get("paused")
        s["waiting"] = e.get("waiting")
        s["done"] = e.get("done")
        s["busy"] = e.get("busy")
        s["asking_dismissed"] = e.get("asking_dismissed")
        cn = s.get("custom_name")
        # ne garder le /rename que s'il est distinct (pas un persona, pas l'ai-title)
        s["custom_name"] = cn if (cn and cn not in pool and cn != s.get("title")) else None
    sessions.sort(key=lambda s: s["mtime"], reverse=True)
    return sessions


def kv(label, val, lw=9):
    """Paire clé/valeur façon header k9s : clé bleu clair alignée, valeur blanche."""
    return c(T_LBL, label.ljust(lw)) + c(T_VAL, str(val))


def hk(key, desc, kw=5):
    """Raccourci façon k9s : touche dodgerblue alignée, description gris clair."""
    return c(T_KEY, key.ljust(max(kw, len(key) + 1))) + c(T_DESC, desc)


def opt(active, label):
    """Option d'un toggle : active = vert avec ▸, inactive = grise."""
    return c(T_ACTIVE, "▸ " + label) if active else c(T_DIM, "  " + label)


def side_by_side(blocks, gap=4):
    """Assemble des blocs de lignes en colonnes juxtaposées (ANSI-aware)."""
    widths = [max((visible_len(x) for x in b), default=0) for b in blocks]
    height = max((len(b) for b in blocks), default=0)
    rows = []
    for i in range(height):
        cells = [pad(b[i] if i < len(b) else "", w) for b, w in zip(blocks, widths)]
        rows.append((" " * gap).join(cells))
    return rows


def box(title, lines, width):
    """Encadre des lignes (déjà à la largeur de contenu) façon k9s. `title` est
    déjà colorisé (on mesure sa largeur visible pour le filet du haut)."""
    inner = max(6, width - 2)        # entre les bordures │ … │
    contentw = inner - 2            # marge d'un espace de chaque côté
    dashes = max(0, inner - visible_len(title) - 3)
    out = [c(T_BORDER, "┌─ ") + title + c(T_BORDER, " " + "─" * dashes + "┐")]
    for ln in lines:
        out.append(c(T_BORDER, "│ ") + pad(ln, contentw) + c(T_BORDER, " │"))
    out.append(c(T_BORDER, "└" + "─" * inner + "┘"))
    return out


def list_capacity(term_lines, paused, extra=0):
    """Nombre de sessions affichables dans le cadre selon la hauteur du terminal.
    En-tête live ≈ 7 lignes (titre + bloc colonnes + blanc) ; +3 lignes de cadre ;
    `extra` = lignes supplémentaires (ex. ligne de filtre)."""
    head = 7 if paused is not None else 2
    return max(1, term_lines - head - 4 - extra)


def matches(s, q):
    """Vrai si la session correspond au filtre (projet, titre ou dernier prompt)."""
    if not q:
        return True
    q = q.lower()
    return (q in (s.get("project") or "").lower()
            or q in (s.get("title") or "").lower()
            or q in (s.get("last_prompt") or "").lower())


def strip_ansi(s):
    out, i = [], 0
    while i < len(s):
        if s[i] == "\033":
            while i < len(s) and s[i] != "m":
                i += 1
            i += 1
        else:
            out.append(s[i])
            i += 1
    return "".join(out)


LEVEL_LABELS = ["normal", "extended", "full"]  # Tab : jacked-in/paused/knocking → +unplugged → +bg

# Ordre d'attention des statuts pour le tri « status » (paused est traité à part :
# toujours relégué en fin de liste, quel que soit le tri).
_STATUS_RANK = {"knocking": 0, "maybe_asking": 1, "active": 2, "standby": 3,
                "live": 4, "idle": 5, "paused": 6}

# Tris disponibles, dans l'ordre de cyclage (touche s) ; libellé = la clé elle-même
# (anglais). Défaut = age. Chaque entrée : (clé, fn(s, now) -> valeur, reverse, full_only).
# reverse n'est utilisé que sur des valeurs numériques (négation dans sort_sessions).
SORT_SPECS = [
    ("age",           lambda s, now: s.get("started") or 0,               True,  False),
    ("last activity", lambda s, now: s["mtime"],                          True,  False),
    ("status",        lambda s, now: _STATUS_RANK.get(status_kind(s, now)[0], 9), False, False),
    ("agent",         lambda s, now: (s.get("agent") or "￿").lower(), False, False),
    ("title",         lambda s, now: (s.get("title") or "").lower(),       False, False),
    ("project",       lambda s, now: (s.get("project") or "").lower(),     False, False),
    ("context",       lambda s, now: s.get("context_tokens") or 0,         True,  True),
]
SORT_BY = {key: (fn, rev, fo) for key, fn, rev, fo in SORT_SPECS}
SORT_LABEL_W = max(len(key) for key, *_ in SORT_SPECS)  # largeur fixe (col1 d'en-tête stable)


def available_sorts(full):
    """Clés de tri proposées selon la vue : `context` seulement en vue complet."""
    return [key for key, _fn, _rev, fo in SORT_SPECS if full or not fo]


def next_sort(sort_key, full):
    """Clé de tri suivante dans le cycle des tris disponibles pour la vue."""
    keys = available_sorts(full)
    if sort_key not in keys:
        return keys[0]
    return keys[(keys.index(sort_key) + 1) % len(keys)]


def sort_sessions(sessions, sort_key):
    """Trie en place selon `sort_key`. Les sessions en pause sont toujours
    reléguées en fin de liste (clé composée), quel que soit le critère."""
    fn, rev, _fo = SORT_BY.get(sort_key, SORT_BY["age"])
    now = time.time()
    def key(s):
        v = fn(s, now)
        return (bool(s.get("paused")), -v if rev else v)
    sessions.sort(key=key)
    return sessions


def ctx_cell(n, ctx_max):
    """Taille de contexte colorée selon le taux de remplissage (vert/jaune/rouge)."""
    txt = fmt_tokens(n)
    if n is None:
        return c(T_DIM, txt)
    r = (n / ctx_max) if ctx_max else 0
    code = T_GREEN if r < 0.6 else T_YELLOW if r < 0.85 else T_RED
    return c(code, txt)


def state_last_age(s, now):
    """Âge affiché en colonne LAST : depuis le plus récent de
    paused.since/waiting.since/done.since si l'un est posé, sinon depuis mtime."""
    stamps = [f.get("since", 0) for f in (s.get("paused"), s.get("waiting"), s.get("done")) if f]
    ref = max(stamps) if stamps else s["mtime"]
    return now - ref


def render(sessions, include_agents, paused=None, interval=None, full=False,
           sel=-1, sort_key="age", ctx_max=200000, top=0, query="", searching=False,
           hide_idle=False, level=0):
    now = time.time()
    when = time.strftime("%H:%M:%S", time.localtime(now))
    n = len(sessions)
    term = shutil.get_terminal_size((120, 40))

    # ---- En-tête multi-colonnes façon k9s (au-dessus du cadre). Pas de titre :
    #      le logo MATRIX en haut à droite (overlay_right) tient ce rôle. ----
    if paused is not None:  # mode live
        col1 = [
            "",  # décale View sous les items (pas au niveau des titres de sections)
            kv("View", LEVEL_LABELS[level]),
            kv("Sort", sort_key.ljust(SORT_LABEL_W)),
            kv("Refresh", "paused" if paused else "%ds" % interval),
            kv("Updated", when),
        ]
        general = [c(T_LBL, "General"),
                   hk("F5", "refresh"), hk("p", "pause"), hk("?", "help"), hk("q", "quit")]
        nav = [c(T_LBL, "Navigation"),
               hk("/", "filter"), hk("s", "sort"),
               hk("Tab", "view"), hk("t", "columns")]
        sess = [c(T_LBL, "Session"),
                hk("⏎", "focus/open"), hk("z", "pause"), hk("x", "dismiss ◔"),
                hk("w", "wake"), hk("d", "detail"), hk("e", "quit sess")]
        # Boutons souris en colonne dédiée, après Session (séparés d'une ligne).
        buttons = ["", c(T_BTN, RED_PILL_BTN) + c(T_DIM, " n"), "",
                   c(T_BTN, WAKE_BTN) + c(T_DIM, " W")]
        out = side_by_side([col1, general, nav, sess, buttons])
        if searching:  # saisie de filtre en cours
            out.append(c(T_KEY, "/") + c(T_VAL, query) + c(T_ACTIVE, "▌"))
        elif query:    # filtre appliqué
            out.append(c(T_LBL, "filter ") + c(T_KEY, "/" + query)
                       + c(T_DIM, "   (Esc clears)"))
        out.append("")
    else:
        out = [""]

    # ---- Tableau encadré. MODEL toujours affiché ; LAST PROMPT prend le reste. ----
    if full:  # complet : + tokens/coût, host, modèle
        fixed = [("AGENT", 15), ("TITLE", 22), ("STATUS", 16), ("PROJECT", 14), ("LAST", 6),
                 ("AGE", 6), ("CTX", 6), ("OUT", 6), ("COST", 7), ("HOST", 7), ("MODEL", 12)]
    else:  # normal / étendu : colonnes minimales
        fixed = [("AGENT", 15), ("TITLE", 30), ("STATUS", 16), ("PROJECT", 16), ("LAST", 6),
                 ("AGE", 6)]
    sep = 2
    box_w = term.columns
    contentw = max(40, box_w - 4)
    used = sum(w for _, w in fixed) + sep * len(fixed)
    prompt_w = max(10, contentw - used)

    HEAD = T_HDR  # en-têtes de colonnes — aqua gras
    head_cells = [pad(c(HEAD, name), w) for name, w in fixed]
    head_cells.append(pad(c(HEAD, "LAST PROMPT"), prompt_w))
    table = [(" " * sep).join(head_cells)]

    # Fenêtre de scroll : en live on n'affiche que ce qui tient ; --once affiche tout.
    if paused is None:
        rows, top = n, 0
    else:
        rows = list_capacity(term.lines, paused, 1 if (searching or query) else 0)
        top = max(0, min(top, max(0, n - rows)))

    if not sessions:
        table.append(c(T_DIM, "(no sessions today)"))
    for idx in range(top, min(top + rows, n)):
        s = sessions[idx]
        st, _ = status(s, now)
        last = state_last_age(s, now)
        started = s.get("started")
        age = (now - started) if started else last
        proj_w = 14 if full else 16
        proj = c(T_DIM, trunc(s["project"], 7) + " [bg]") if s.get("background") \
            else trunc(s["project"], proj_w)
        ag = s.get("agent")
        agent_cell = c(T_GREEN, trunc(ag, 15)) if ag else c(T_DIM, "—")
        if full:
            model = pad(c(model_color(s.get("model")), trunc(short_model(s.get("model")), 12)), 12)
            cells = [pad(agent_cell, 15), pad(title_cell(s, 22), 22), pad(st, 16),
                     pad(proj, 14), pad(fmt_age(last), 6), pad(fmt_age(age), 6),
                     pad(ctx_cell(s.get("context_tokens"), ctx_max), 6),
                     pad(fmt_tokens(s.get("output_total")), 6),
                     pad(fmt_cost(s.get("cost")), 7), pad(host_cell(s), 7), model]
        else:
            cells = [pad(agent_cell, 15), pad(title_cell(s, 30), 30), pad(st, 16),
                     pad(proj, 16), pad(fmt_age(last), 6), pad(fmt_age(age), 6)]
        cells.append(pad(trunc(s["last_prompt"], prompt_w), prompt_w))
        row = (" " * sep).join(cells)
        if idx == sel:  # ligne sélectionnée : bande gris foncé discrète (préserve les couleurs)
            if USE_COLOR:
                band, reset = "\033[%sm" % T_SELECT, "\033[0m"
                row = band + pad(row, contentw).replace(reset, reset + band) + reset
            else:
                row = ("> " + strip_ansi(row))[:contentw]
        table.append(row)

    title = c(T_TITLE, "Sessions[%d]" % n)
    if rows < n:  # liste tronquée : indiquer la plage visible
        title += c(T_DIM, "  %d-%d" % (top + 1, min(top + rows, n)))
    if paused is not None and USE_COLOR:  # logo Matrix calé en haut à droite
        out = logo.overlay_right(out, term.columns)
    out += box(title, table, box_w)
    return "\n".join(out)


def oneline(s):
    return " ".join((s or "").split())


def fmt_dur(sec):
    if sec < 60:
        return "%ds" % sec
    if sec < 3600:
        return "%dm" % (sec // 60)
    return "%dh%02d" % (sec // 3600, (sec % 3600) // 60)


def parse_ts(s):
    if not s:
        return None
    try:
        import datetime
        return datetime.datetime.fromisoformat(s.replace("Z", "+00:00")).timestamp()
    except Exception:
        return None


def text_and_tools(content):
    """Extrait le texte et compte les appels d'outils d'un content (str ou blocs)."""
    if isinstance(content, str):
        return content, 0
    texts, tools = [], 0
    if isinstance(content, list):
        for b in content:
            if not isinstance(b, dict):
                continue
            if b.get("type") == "text":
                texts.append(b.get("text", ""))
            elif b.get("type") == "tool_use":
                tools += 1
    return " ".join(texts).strip(), tools


def build_detail(session):
    """Métadonnées + résumé condensé des tours de la session (pour la vue détail)."""
    try:
        with open(session.get("path")) as f:
            raw = f.readlines()
    except Exception:
        return [c("90", "(transcript unreadable)")]

    turns = []
    cur = None
    first_ts = last_ts = None
    out_total = ctx_now = n_assist = 0
    model = None
    for line in raw:
        if '"assistant"' not in line and '"user"' not in line:
            continue
        try:
            obj = json.loads(line)
        except Exception:
            continue
        t = obj.get("type")
        ts = parse_ts(obj.get("timestamp"))
        if ts:
            if first_ts is None:
                first_ts = ts
            last_ts = ts
        msg = obj.get("message") or {}
        if t == "user":
            txt, _ = text_and_tools(msg.get("content"))
            if txt:  # on ignore les tours user qui ne portent qu'un tool_result
                cur = {"ts": ts, "prompt": txt, "tools": 0, "out": 0, "reply": ""}
                turns.append(cur)
        elif t == "assistant":
            n_assist += 1
            u = msg.get("usage") or {}
            out_total += u.get("output_tokens") or 0
            ctx_now = ((u.get("input_tokens") or 0)
                       + (u.get("cache_read_input_tokens") or 0)
                       + (u.get("cache_creation_input_tokens") or 0))
            if msg.get("model"):
                model = msg.get("model")
            txt, tools = text_and_tools(msg.get("content"))
            if cur is not None:
                cur["tools"] += tools
                cur["out"] += u.get("output_tokens") or 0
                if txt and not cur["reply"]:
                    cur["reply"] = txt

    dur = fmt_dur(int(last_ts - first_ts)) if (first_ts and last_ts) else "—"
    mcol1 = [kv("Project", session.get("project") or "—"),
             kv("Branch", session.get("branch") or "—"),
             kv("Session", (session.get("sid") or "")[:8])]
    mcol2 = [kv("Model", short_model(model), 11),
             kv("Turns", len(turns), 11),
             kv("Asst msgs", n_assist, 11)]
    mcol3 = [kv("Context", fmt_tokens(ctx_now), 11),
             kv("Generated", fmt_tokens(out_total), 11),
             kv("Duration", dur, 11)]
    lines = [c(T_LOGO, session.get("title", "") or "(untitled)"), ""]
    lines += side_by_side([mcol1, mcol2, mcol3])
    lines += ["", c(T_HDR, "CONVERSATION TURNS")]
    for i, trn in enumerate(turns, 1):
        hh = time.strftime("%H:%M", time.localtime(trn["ts"])) if trn["ts"] else "--:--"
        lines.append(c(T_KEY, "%3d." % i) + " " + c(T_DIM, hh) + "  "
                     + c(T_VAL, trunc(oneline(trn["prompt"]), 110)))
        meta = []
        if trn["out"]:
            meta.append("%s tok" % fmt_tokens(trn["out"]))
        if trn["tools"]:
            meta.append("%d tool(s)" % trn["tools"])
        sub = "      " + c(T_DIM, " · ".join(meta))
        if trn["reply"]:
            sub += c(T_DIM, "  →  " + trunc(oneline(trn["reply"]), 90))
        if meta or trn["reply"]:
            lines.append(sub)
    return lines


def render_detail(lines, scroll, session):
    term = shutil.get_terminal_size((120, 40))
    height = max(3, term.lines - 6)
    total = len(lines)
    scroll = max(0, min(scroll, max(0, total - height)))
    head = [
        c(T_LOGO, "Session detail"),
        "   ".join([hk("↑↓", "scroll"), hk("PgUp/Dn", "page", 11),
                    hk("g/G", "top/bottom"), hk("Esc", "back"),
                    hk("q", "quit")]),
        "",
    ]
    window = lines[scroll:scroll + height]
    pos = ("%d–%d / %d" % (scroll + 1, min(scroll + height, total), total)) if total else "0"
    return "\n".join(head + window + ["", c(T_DIM, pos)]), scroll


def help_lines(width):
    """Sections encadrées de l'aide (`?`) : raccourcis groupés puis statuts.
    Les cadres prennent toute la largeur `width` de la fenêtre."""
    def kd(key, desc):
        return c(T_KEY, key.ljust(12)) + c(T_DESC, desc)

    nav = [kd("↑↓ / j k", "navigate"), kd("PgUp/PgDn", "page"), kd("g / G", "top / bottom"),
           kd("/", "filter (Esc clears)"), kd("s", "sort (cycle columns)"),
           kd("Tab", "view: normal / extended / full (+ background sessions)"),
           kd("t", "toggle detailed columns (CTX/OUT/COST/HOST/MODEL)")]
    session = [kd("Enter", "focus the window, or resume if closed"),
               kd("z", "pause this session"), kd("w", "wake this session"),
               kd("x", "dismiss ◔ maybe-asking (false positive)"),
               kd("d", "detail view"), kd("e", "quit session (/exit + close kitty window)"),
               kd("Ctrl+K", "kill (SIGTERM)")]
    general = [kd("F5 / r", "refresh"), kd("p", "pause / resume auto-refresh"),
               kd("n", "Red Pill — open the menu (new window) to resume a recent"),
               kd("", "session or start a new one (pick repo + name)"),
               kd("W", "Wake Up Neo — wake every paused session at once:"),
               kd("", "focus it if still open, resume it if its window was closed"),
               kd("?", "toggle this help"), kd("q", "quit")]
    descs = {
        "active": "turn in progress (Claude working)",
        "live": "process alive, idle (no current turn)",
        "knocking": "waiting for your answer (AskUserQuestion / permission)",
        "maybe_asking": "last message looks like a question (heuristic — x to dismiss)",
        "standby": "turn finished, terminal still open",
        "idle": "process gone or stale",
        "paused": "manually paused",
    }
    statuses = [pad(c(code, STATUS_META[kind][1]), 16) + c(T_DESC, descs[kind])
                for kind in ("active", "live", "knocking", "maybe_asking",
                             "standby", "idle", "paused")
                for code in (STATUS_META[kind][0],)]

    # Ordre aligné sur l'en-tête de la vue normale (General, Navigation, Session).
    # Cadres à pleine largeur de la fenêtre.
    sections = [("General", general), ("Navigation", nav),
                ("Session", session), ("Statuses", statuses)]
    out = []
    for title, rows in sections:
        out += box(c(T_LBL, title), rows, width) + [""]
    return out


def render_help(scroll):
    term = shutil.get_terminal_size((120, 40))
    height = max(3, term.lines - 6)
    lines = help_lines(term.columns)
    total = len(lines)
    scroll = max(0, min(scroll, max(0, total - height)))
    head = [
        c(T_LOGO, "The Matrix — help"),
        "   ".join([hk("↑↓", "scroll"), hk("PgUp/Dn", "page", 11),
                    hk("g/G", "top/bottom"), hk("Esc", "back"), hk("q", "quit")]),
        "",
    ]
    window = lines[scroll:scroll + height]
    pos = ("%d–%d / %d" % (scroll + 1, min(scroll + height, total), total)) if total else "0"
    return "\n".join(head + window + ["", c(T_DIM, pos)]), scroll


def render_kill(ctx):
    """Écran de fermeture : choix du process à tuer (SIGTERM) puis confirmation.
    `ctx` = {sess, cands, sel, denied, result?}."""
    s = ctx["sess"]
    lines = [c(T_LOGO, "Fermer une session — SIGTERM"), "",
             kv("Project", s.get("project") or "—"),
             kv("Title", trunc(s.get("title") or "—", 60)),
             kv("Cwd", s.get("cwd") or "—"),
             kv("Session", (s.get("sid") or "")[:8]), ""]

    res = ctx.get("result")
    if res:
        kind, info = res
        if kind == "ok":
            lines.append(c(T_GREEN, "✓ SIGTERM envoyé au PID %s." % info))
            lines.append(c(T_DIM, "La session passera en ○ idle au prochain refresh "
                                  "(le transcript reste sur disque)."))
        elif kind == "gone":
            lines.append(c(T_YELLOW, "Le PID %s n'existait déjà plus." % info))
        else:
            lines.append(c(T_RED, "Échec : %s" % info))
        lines += ["", "   ".join([hk("Esc", "back"), hk("q", "quit")])]
        return "\n".join(lines)

    if ctx.get("denied"):
        lines.append(c(T_RED, "/proc inaccessible — impossible d'identifier le process."))
        lines += ["", "   ".join([hk("Esc", "back"), hk("q", "quit")])]
        return "\n".join(lines)

    cands = ctx["cands"]
    if not cands:
        lines.append(c(T_YELLOW, "Aucun process claude vivant pour cette session."))
        lines.append(c(T_DIM, "Elle est déjà terminée — rien à tuer "
                              "(le transcript reste sur disque)."))
        lines += ["", "   ".join([hk("Esc", "back"), hk("q", "quit")])]
        return "\n".join(lines)

    if len(cands) == 1:
        lines.append(c(T_VAL, "1 process trouvé pour ce dossier :"))
    else:
        lines.append(c(T_YELLOW, "%d process tournent dans ce dossier — "
                       "choisis lequel fermer :" % len(cands)))
    lines.append("")
    now = time.time()
    for i, p in enumerate(cands):
        mark = c(T_ACTIVE, "▸ ") if i == ctx["sel"] else "  "
        age = fmt_age(now - p["started"]) if p.get("started") else "—"
        tags = []
        if p.get("entrypoint"):
            tags.append(p["entrypoint"])
        if p.get("resume_id"):
            tags.append("resume:" + p["resume_id"][:8])
        tag = c(T_DIM, "  " + " · ".join(tags)) if tags else ""
        reliable = c(T_GREEN, "  ✓ lien fiable") \
            if p.get("resume_id") == s.get("sid") else ""
        lines.append(mark + "PID " + c(T_VAL, str(p["pid"]))
                     + c(T_DIM, "   âge ") + age + tag + reliable)
    lines += ["", "   ".join([hk("↑↓", "choose"), hk("y", "close (SIGTERM)"),
                              hk("Esc", "cancel"), hk("q", "quit")])]
    return "\n".join(lines)


def render_exit(ctx):
    """Écran d'exit propre : `/exit` envoyé à Claude puis fermeture de la fenêtre kitty.
    `ctx` = {sess, result?}."""
    s = ctx["sess"]
    lines = [c(T_LOGO, "Exit propre — /exit puis fermeture de la fenêtre kitty"), "",
             kv("Project", s.get("project") or "—"),
             kv("Title", trunc(s.get("title") or "—", 60)),
             kv("Cwd", s.get("cwd") or "—"),
             kv("Session", (s.get("sid") or "")[:8]), ""]

    res = ctx.get("result")
    if res:
        kind, _info = res
        if kind == "ok":
            lines.append(c(T_GREEN, "✓ /exit envoyé, fenêtre fermée."))
            lines.append(c(T_DIM, "SessionEnd nettoie le registre et libère le persona."))
        else:
            lines.append(c(T_YELLOW, "Aucune fenêtre kitty joignable pour cette session."))
            lines.append(c(T_DIM, "Pas de binding kitty (lancée hors matrix) ou déjà fermée."))
        lines += ["", "   ".join([hk("Esc", "back"), hk("q", "quit")])]
        return "\n".join(lines)

    lines.append(c(T_VAL, "Envoyer /exit à la session et fermer sa fenêtre ?"))
    lines.append(c(T_DIM, "Sortie propre (SessionEnd) — le transcript reste sur disque."))
    lines += ["", "   ".join([hk("⏎", "exit + close"), hk("Esc", "cancel"), hk("q", "quit")])]
    return "\n".join(lines)


def read_key(timeout):
    """Lit une touche. Retourne 'UP'/'DOWN'/'ENTER'/'ESC'/'PGUP'/… ou le caractère.
    None si le délai expire. Distingue Esc seul d'une séquence de flèche."""
    r, _, _ = select.select([sys.stdin], [], [], timeout)
    if not r:
        return None
    ch = os.read(sys.stdin.fileno(), 1)
    if ch in (b"\r", b"\n"):
        return "ENTER"
    if ch != b"\x1b":
        try:
            return ch.decode("utf-8", "ignore")
        except Exception:
            return ""
    # Octet d'échappement : séquence (flèche, PgUp…) ou Esc seul si rien ne suit.
    r2, _, _ = select.select([sys.stdin], [], [], 0.02)
    if not r2:
        return "ESC"
    seq = os.read(sys.stdin.fileno(), 32).decode("latin1", "ignore")
    if seq.startswith("[<"):  # événement souris SGR (1006) : "[<b;col;row(M|m)"
        final = seq.strip()[-1] if seq.strip() else ""
        try:
            button, col, row = (int(x) for x in seq[2:].rstrip("Mm").split(";"))
        except (ValueError, IndexError):
            return None
        if button == 64:
            return "MUP"      # molette vers le haut
        if button == 65:
            return "MDOWN"    # molette vers le bas
        if button == 0 and final == "M":   # clic gauche (press) → (col, row) 1-based
            return ("CLICK", col, row)
        return None           # relâchement / autre bouton : ignoré
    return {
        "[A": "UP", "[B": "DOWN", "[C": "RIGHT", "[D": "LEFT",
        "OA": "UP", "OB": "DOWN", "OC": "RIGHT", "OD": "LEFT",
        "[5~": "PGUP", "[6~": "PGDN",
        "[15~": "F5",
        "[H": "HOME", "[F": "END", "[1~": "HOME", "[4~": "END",
    }.get(seq, "ESC")


RED_PILL_BTN = "[💊 Red Pill]"     # bouton souris : lance redpill en nouvelle fenêtre kitty
WAKE_BTN = "[⏰ Wake Up Neo]"      # bouton souris : réveille toutes les sessions en pause


def button_region(screen_str, marker=RED_PILL_BTN):
    """(row, c0, c1) 1-based du bouton `marker` dans l'écran rendu, ou None."""
    for i, line in enumerate(screen_str.split("\n")):
        pos = strip_ansi(line).find(marker)
        if pos != -1:
            return (i + 1, pos + 1, pos + 1 + len(marker))
    return None


def parse_args(argv):
    opts = {"once": False, "all": False, "full": False, "hide_idle": False,
            "interval": 10, "ctx_max": 200000}
    i = 0
    while i < len(argv):
        a = argv[i]
        if a in ("--once", "-1"):
            opts["once"] = True
        elif a in ("--all", "-a"):
            opts["all"] = True
        elif a in ("--full", "-f"):
            opts["full"] = True
        elif a == "--hide-idle":
            opts["hide_idle"] = True
        elif a in ("--interval", "-n") and i + 1 < len(argv):
            try:
                opts["interval"] = max(2, int(argv[i + 1]))
            except ValueError:
                pass
            i += 1
        elif a == "--ctx-max" and i + 1 < len(argv):
            try:
                opts["ctx_max"] = max(1000, int(argv[i + 1]))
            except ValueError:
                pass
            i += 1
        elif a in ("--help", "-h"):
            print(__doc__)
            sys.exit(0)
        i += 1
    return opts


def _kitty_focus(sock, match):
    """Tente `kitty @ focus-window` sur l'instance `sock` avec le critère `match`.
    Renvoie True seulement si une fenêtre a été trouvée et focus (returncode 0)."""
    if not sock:
        return False
    if not sock.startswith("unix:"):
        sock = "unix:" + sock
    try:
        r = subprocess.run(["kitty", "@", "--to", sock, "focus-window", "--match", match],
                           timeout=5, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
        return r.returncode == 0
    except Exception:
        return False


def _kitty_run(sock, args):
    """Lance `kitty @ --to <sock> <args…>` (best-effort). True si returncode 0."""
    if sock and not sock.startswith("unix:"):
        sock = "unix:" + sock
    try:
        r = subprocess.run(["kitty", "@", "--to", sock] + list(args),
                           timeout=5, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
        return r.returncode == 0
    except Exception:
        return False


def _kitty_targets(sess):
    """(sock, match) pour joindre la fenêtre kitty de la session : binding enregistré
    d'abord (précis, `id:`), puis découverte par titre (agent) et cwd sur les instances
    kitty. À essayer dans l'ordre, en s'arrêtant à la première qui répond."""
    targets = []
    if sess.get("mx_socket") and sess.get("mx_window"):
        targets.append((sess["mx_socket"], "id:%s" % sess["mx_window"]))
    criteria = []
    if sess.get("agent"):
        criteria.append("title:%s" % sess["agent"])
    if sess.get("cwd"):
        criteria.append("cwd:%s" % sess["cwd"])
    for sock in glob.glob("/tmp/kitty-*"):
        for match in criteria:
            targets.append((sock, match))
    return targets


def clean_exit(sess):
    """Exit propre : envoie `/exit` à la session Claude (slash command → hook
    SessionEnd, donc nettoyage du registre + libération du persona), puis ferme sa
    fenêtre kitty. Essaie les cibles dans l'ordre et s'arrête à la première fenêtre
    joignable. Renvoie ('ok', match) ou ('nowin', None)."""
    for sock, match in _kitty_targets(sess):
        if _kitty_run(sock, ["send-text", "--match", match, "/exit\r"]):
            time.sleep(1.5)  # laisse Claude traiter /exit (SessionEnd) avant de fermer
            _kitty_run(sock, ["close-window", "--match", match])
            return ("ok", match)
    return ("nowin", None)


def focus_or_open(sess):
    """Focus la fenêtre kitty de la session ; sinon ouvre une reprise personnifiée.

    1) binding enregistré (mx_socket + mx_window) ; 2) à défaut, découverte parmi
    les instances kitty en matchant le titre (nom d'agent) puis le cwd ; 3) sinon,
    reprise dans une nouvelle fenêtre."""
    agent, cwd = sess.get("agent"), sess.get("cwd")
    if sess.get("mx_window") and _kitty_focus(sess.get("mx_socket"), "id:%s" % sess["mx_window"]):
        return
    criteria = []
    if agent:
        criteria.append("title:%s" % agent)
    if cwd:
        criteria.append("cwd:%s" % cwd)
    for sock in glob.glob("/tmp/kitty-*"):
        for match in criteria:
            if _kitty_focus(sock, match):
                return
    try:
        subprocess.Popen(["kitty", "--directory", cwd or os.path.expanduser("~"),
                          "zsh", "-ic", "construct resume %s" % sess["sid"]],
                         start_new_session=True, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
    except Exception:
        pass


def open_redpill():
    """Ouvre redpill (choix / reprise de session) dans une nouvelle fenêtre kitty."""
    try:
        subprocess.Popen(["kitty", "zsh", "-ic", "redpill"],
                         start_new_session=True, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
    except Exception:
        pass


def toggle_pause(sess):
    """Bascule le flag paused de la session. Auto-note : waiting.message si présent,
    sinon dernier prompt/titre. (Édition inline non couverte ici — v1 : note auto.)"""
    import matrix_lib
    sid = sess["sid"]
    if sess.get("paused"):
        matrix_lib.clear_paused(sid)
        return
    w = sess.get("waiting") or {}
    note = w.get("message") or sess.get("last_prompt") or sess.get("title") or ""
    matrix_lib.set_paused(sid, note=note, cwd=sess.get("cwd"))


def toggle_asking_dismissed(sess, now):
    """Masque / ré-affiche l'état heuristique ◔ maybe-asking d'une session (faux
    positif). Ne pose le masque que si la session est effectivement en maybe-asking ;
    le clear reste toujours possible. Masque transitoire : levé au prochain tour."""
    import matrix_lib
    sid = sess["sid"]
    if sess.get("asking_dismissed"):
        matrix_lib.clear_asking_dismissed(sid)
    elif status_kind(sess, now)[0] == "maybe_asking":
        matrix_lib.set_asking_dismissed(sid, cwd=sess.get("cwd"))


def wake_all():
    """Réveille toutes les sessions en pause (focus/rouvre chacune), efface leur flag.
    Renvoie le nombre de sessions traitées."""
    import matrix_lib
    sys.stderr.write("\n\033[32mWake up, Neo…\033[0m\n\n")
    sys.stderr.flush()
    time.sleep(0.6)
    paused = matrix_lib.paused_sessions()
    for p in paused:
        try:
            focus_or_open({"sid": p["sid"], "cwd": p.get("cwd"), "agent": p.get("agent")})
            matrix_lib.clear_paused(p["sid"])
        except Exception:
            pass
    return len(paused)


def run_live(opts):
    level = 2 if opts["all"] else 0  # 0 normal · 1 étendu · 2 complet (+ sessions de fond)
    show_all, hide_idle = level == 2, level == 0
    detailed = opts["full"]  # colonnes détaillées (CTX/OUT/COST/HOST/MODEL), touche t
    paused = False
    sort_key = "age"
    sel = 0
    ctx_max = opts["ctx_max"]
    query = ""            # filtre actif
    searching = False     # saisie du filtre en cours
    kill_ctx = None       # contexte de l'écran de fermeture (SIGTERM)
    exit_ctx = None       # contexte de l'écran d'exit propre (/exit + close-window)

    if not sys.stdin.isatty():  # non interactif (pipe, watch…) : refresh simple
        while True:
            sys.stdout.write("\033[H\033[J")
            s = drop_idle(sort_sessions(collect(show_all, with_tokens=detailed), sort_key),
                          hide_idle)
            sys.stdout.write(render(s, show_all, paused=False,
                             interval=opts["interval"], full=detailed,
                             sort_key=sort_key, ctx_max=ctx_max,
                             hide_idle=hide_idle, level=level) + "\n")
            sys.stdout.flush()
            time.sleep(opts["interval"])
        return

    def need_tokens():
        return detailed or sort_key == "context"

    def refresh():
        # Indicateur transitoire en bas d'écran pendant la collecte (synchrone) :
        # visible surtout en vue complète / grand nombre de sessions.
        if USE_COLOR:
            term = shutil.get_terminal_size((120, 40))
            sys.stdout.write("\033[%d;1H" % term.lines
                             + c(T_ACTIVE, "⟳ refreshing…") + "\033[K")
            sys.stdout.flush()
        return sort_sessions(collect(show_all, with_tokens=need_tokens()), sort_key)

    old = termios.tcgetattr(sys.stdin)
    tty.setcbreak(sys.stdin.fileno())
    # Écran alterné (comme k9s/top/vim) : ne pollue pas le scrollback, et restitue
    # le terminal intact à la sortie. + curseur masqué + tracking molette (SGR 1006).
    sys.stdout.write("\033[?1049h\033[?25l\033[?1000h\033[?1006h")
    screen = "list"
    detail = None
    detail_lines = []
    scroll = 0
    top = 0
    sessions = refresh()
    try:
        while True:
            if screen == "list":
                view = drop_idle([s for s in sessions if matches(s, query)], hide_idle)
                if sel >= len(view):
                    sel = max(0, len(view) - 1)
                # Fenêtre de scroll : garder la ligne sélectionnée visible.
                extra = 1 if (searching or query) else 0
                rows = list_capacity(shutil.get_terminal_size((120, 40)).lines, paused, extra)
                if sel < top:
                    top = sel
                elif sel >= top + rows:
                    top = sel - rows + 1
                top = max(0, min(top, max(0, len(view) - rows)))
                screen_str = render(view, show_all, paused=paused,
                                    interval=opts["interval"], full=detailed, sel=sel,
                                    sort_key=sort_key, ctx_max=ctx_max, top=top,
                                    query=query, searching=searching,
                                    hide_idle=hide_idle, level=level)
                sys.stdout.write("\033[H\033[J")
                sys.stdout.write(screen_str + "\n")
                sys.stdout.flush()
                btn = button_region(screen_str)
                k = read_key(None if (paused or searching) else opts["interval"])
                if k is None:           # timeout → auto-refresh
                    sessions = refresh()
                    continue
                if isinstance(k, tuple) and k[0] == "CLICK":  # boutons Red Pill / Wake Up Neo
                    if btn and k[2] == btn[0] and btn[1] <= k[1] < btn[2]:
                        open_redpill()
                        continue
                    wbtn = button_region(screen_str, WAKE_BTN)
                    if wbtn and k[2] == wbtn[0] and wbtn[1] <= k[1] < wbtn[2]:
                        wake_all()
                        sessions = refresh()
                        continue
                    continue
                if searching:           # saisie du filtre en cours
                    if k == "ENTER":
                        searching = False
                    elif k == "ESC":
                        searching, query = False, ""
                    elif k in ("\x7f", "\x08"):     # backspace
                        query = query[:-1]
                    elif len(k) == 1 and k.isprintable():
                        query += k
                    sel = 0
                    continue
                if k in ("q", "Q"):
                    break
                elif k == "/":
                    searching, sel = True, 0
                elif k == "z" and view:
                    toggle_pause(view[sel])
                    sessions = refresh()
                elif k == "x" and view:
                    toggle_asking_dismissed(view[sel], time.time())
                    sessions = refresh()
                elif k == "w" and view:
                    import matrix_lib
                    focus_or_open(view[sel])
                    matrix_lib.clear_paused(view[sel]["sid"])
                    sessions = refresh()
                elif k in ("n", "N"):
                    open_redpill()
                elif k == "W":
                    wake_all()
                    sessions = refresh()
                elif k in ("d", "D") and view:
                    detail = view[sel]
                    detail_lines = build_detail(detail)
                    scroll = 0
                    screen = "detail"
                elif k == "?":
                    scroll = 0
                    screen = "help"
                elif k == "\x0b" and view:   # Ctrl+K
                    sess = view[sel]
                    procs = claude_procs()
                    kill_ctx = {"sess": sess, "cands": kill_candidates(sess, procs) or [],
                                "sel": 0, "denied": procs is None}
                    screen = "kill"
                elif k in ("e", "E") and view:
                    exit_ctx = {"sess": view[sel]}
                    screen = "exit"
                elif k in ("UP", "k", "K"):
                    sel = max(0, sel - 1)
                elif k in ("DOWN", "j", "J"):
                    sel = min(len(view) - 1, sel + 1) if view else 0
                elif k == "PGUP":
                    sel = max(0, sel - rows)
                elif k == "PGDN":
                    sel = min(len(view) - 1, sel + rows) if view else 0
                elif k == "MUP":
                    sel = max(0, sel - 3)
                elif k == "MDOWN":
                    sel = min(len(view) - 1, sel + 3) if view else 0
                elif k in ("g", "HOME"):
                    sel = 0
                elif k in ("G", "END"):
                    sel = (len(view) - 1) if view else 0
                elif k == "\t":  # Tab : cycle normal → extended → full (sessions affichées)
                    level = (level + 1) % 3
                    show_all, hide_idle = level == 2, level == 0
                    sessions = refresh()
                    sel = 0
                elif k in ("t", "T"):  # bascule les colonnes détaillées (indépendant du niveau)
                    detailed = not detailed
                    if sort_key not in available_sorts(detailed):
                        sort_key = "age"  # le tri context exige les colonnes détaillées
                    sessions = refresh()
                    sel = 0
                elif k in ("s", "S"):
                    sort_key = next_sort(sort_key, detailed)
                    sessions = refresh()
                    sel = 0
                elif k in ("p", "P"):
                    paused = not paused
                elif k in ("F5", "r"):
                    sessions = refresh()
                elif k == "ENTER" and view:
                    focus_or_open(view[sel])
            elif screen == "kill":  # écran de fermeture : refresh suspendu
                sys.stdout.write("\033[H\033[J")
                sys.stdout.write(render_kill(kill_ctx) + "\n")
                sys.stdout.flush()
                k = read_key(None)
                cands = kill_ctx["cands"]
                if kill_ctx.get("result"):       # action faite : seule sortie possible
                    if k in ("ESC", "LEFT"):
                        screen = "list"
                    elif k in ("q", "Q"):
                        break
                elif k in ("ESC", "LEFT"):
                    screen = "list"
                elif k in ("q", "Q"):
                    break
                elif cands and k in ("UP", "k", "K"):
                    kill_ctx["sel"] = max(0, kill_ctx["sel"] - 1)
                elif cands and k in ("DOWN", "j", "J"):
                    kill_ctx["sel"] = min(len(cands) - 1, kill_ctx["sel"] + 1)
                elif cands and k in ("y", "Y", "ENTER"):
                    target = cands[kill_ctx["sel"]]
                    try:
                        os.kill(target["pid"], signal.SIGTERM)
                        kill_ctx["result"] = ("ok", target["pid"])
                    except ProcessLookupError:
                        kill_ctx["result"] = ("gone", target["pid"])
                    except Exception as e:
                        kill_ctx["result"] = ("err", str(e))
                    sessions = refresh()
            elif screen == "exit":  # écran d'exit propre : refresh suspendu
                sys.stdout.write("\033[H\033[J")
                sys.stdout.write(render_exit(exit_ctx) + "\n")
                sys.stdout.flush()
                k = read_key(None)
                if exit_ctx.get("result"):       # action faite : seule sortie possible
                    if k in ("ESC", "LEFT"):
                        screen = "list"
                    elif k in ("q", "Q"):
                        break
                elif k in ("ESC", "LEFT"):
                    screen = "list"
                elif k in ("q", "Q"):
                    break
                elif k == "ENTER":
                    exit_ctx["result"] = clean_exit(exit_ctx["sess"])
                    sessions = refresh()
            elif screen == "help":  # écran d'aide : refresh suspendu
                sys.stdout.write("\033[H\033[J")
                content, scroll = render_help(scroll)
                sys.stdout.write(content + "\n")
                sys.stdout.flush()
                k = read_key(None)
                if k in ("ESC", "LEFT", "?"):
                    screen = "list"
                elif k in ("q", "Q"):
                    break
                elif k in ("UP", "k", "K"):
                    scroll -= 1
                elif k in ("DOWN", "j", "J"):
                    scroll += 1
                elif k == "MUP":
                    scroll -= 3
                elif k == "MDOWN":
                    scroll += 3
                elif k == "PGUP":
                    scroll -= 10
                elif k == "PGDN":
                    scroll += 10
                elif k in ("g", "HOME"):
                    scroll = 0
                elif k in ("G", "END"):
                    scroll = 10 ** 9
            else:  # vue détail : refresh suspendu
                sys.stdout.write("\033[H\033[J")
                content, scroll = render_detail(detail_lines, scroll, detail)
                sys.stdout.write(content + "\n")
                sys.stdout.flush()
                k = read_key(None)
                if k in ("ESC", "LEFT"):
                    screen = "list"
                elif k in ("q", "Q"):
                    break
                elif k in ("UP", "k", "K"):
                    scroll -= 1
                elif k in ("DOWN", "j", "J"):
                    scroll += 1
                elif k == "PGUP":
                    scroll -= 10
                elif k == "PGDN":
                    scroll += 10
                elif k == "MUP":
                    scroll -= 3
                elif k == "MDOWN":
                    scroll += 3
                elif k in ("g", "HOME"):
                    scroll = 0
                elif k in ("G", "END"):
                    scroll = 10 ** 9
    except KeyboardInterrupt:
        pass
    finally:
        # Coupe le tracking souris, réaffiche le curseur, quitte l'écran alterné.
        sys.stdout.write("\033[?1000l\033[?1006l\033[?25h\033[?1049l")
        sys.stdout.flush()
        termios.tcsetattr(sys.stdin, termios.TCSADRAIN, old)


def main():
    opts = parse_args(sys.argv[1:])
    if opts["once"]:
        sessions = drop_idle(
            sort_sessions(collect(opts["all"], with_tokens=opts["full"]), 0),
            opts["hide_idle"])
        print(render(sessions, opts["all"], full=opts["full"],
                     ctx_max=opts["ctx_max"], hide_idle=opts["hide_idle"]))
    else:
        run_live(opts)


if __name__ == "__main__":
    main()
