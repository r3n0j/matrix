#!/usr/bin/env python3
"""redpill — choisis ta réalité : reprendre une session Claude récente, ou en démarrer une.

Menu au lancement (sélecteur interactif : ↑↓ pour naviguer, tape pour filtrer,
Entrée pour valider, Échap pour annuler) :
  - liste des sessions récentes → sélection directe = reprise personnifiée
    (`matrix resume <uuid>` dans le dossier de la session) ;
  - entrée « ＋ nouvelle session… » (ou Échap) = nouvelle session → choix d'un repo.

Sans TTY interactif (sortie redirigée), on retombe sur un menu numéroté simple.
"""
import os
import re
import select as _select_mod
import sys
import termios
import time
import tty

sys.path.insert(0, os.path.dirname(os.path.abspath(__file__)))
import matrix_lib as m

REPOS = os.path.expanduser("~/Arx/repositories")
HOME = os.path.expanduser("~")
GREEN, BRIGHT, DIM, RESET = "\033[32m", "\033[92m", "\033[2m", "\033[0m"

NOTTY = object()  # sentinelle : pas de terminal interactif -> fallback appelant


def fmt_age(sec):
    sec = int(sec)
    if sec < 60:
        return "%ds" % sec
    if sec < 3600:
        return "%dm" % (sec // 60)
    if sec < 86400:
        return "%dh" % (sec // 3600)
    return "%dd" % (sec // 86400)


def trunc(s, n):
    s = s or ""
    return s if len(s) <= n else s[:n - 1] + "…"


def list_repos():
    try:
        return sorted(d for d in os.listdir(REPOS)
                      if os.path.isdir(os.path.join(REPOS, d)) and not d.startswith("."))
    except OSError:
        return []


# ── Sélecteur interactif (mode raw, stdlib) ─────────────────────────────────

def _parse_mouse(seq):
    """Séquence SGR `<b;col;ligneM/m` -> ('click', ligne) | ('wheel', ±1) | 'other'."""
    m = re.match(rb"<(\d+);(\d+);(\d+)([Mm])", seq)
    if not m:
        return "other"
    button, _, row, final = int(m.group(1)), int(m.group(2)), int(m.group(3)), m.group(4)
    if button & 64:
        return "wheel", (1 if button & 1 else -1)
    if (button & 3) == 0 and final == b"M":
        return "click", row
    return "other"


def _read_key(fd):
    """Lit une touche logique sur un fd en mode raw. Renvoie un token, un tuple ou un caractère."""
    ch = os.read(fd, 1)
    if not ch:
        return "eof"
    if ch == b"\x03":
        return "ctrl-c"
    if ch in (b"\r", b"\n"):
        return "enter"
    if ch in (b"\x7f", b"\x08"):
        return "backspace"
    if ch == b"\x0e":  # Ctrl-N
        return "down"
    if ch == b"\x10":  # Ctrl-P
        return "up"
    if ch == b"\x1b":
        rdy, _, _ = _select_mod.select([fd], [], [], 0.02)
        if not rdy:
            return "esc"
        if os.read(fd, 1) != b"[":
            return "other"
        seq = b""
        while True:
            rdy, _, _ = _select_mod.select([fd], [], [], 0.05)
            if not rdy:
                break
            c = os.read(fd, 1)
            seq += c
            if 0x40 <= c[0] <= 0x7e:  # octet final d'une séquence CSI
                break
        if seq in (b"A", b"OA"):
            return "up"
        if seq in (b"B", b"OB"):
            return "down"
        if seq[:1] == b"<":
            return _parse_mouse(seq)
        return "other"
    try:
        dec = ch.decode("utf-8")
        return dec if dec.isprintable() else "other"
    except UnicodeDecodeError:
        return "other"


def _cursor_row(fd):
    """Interroge la position du curseur (DSR) et renvoie sa ligne (1-based) ou None."""
    os.write(fd, b"\x1b[6n")
    resp = b""
    while True:
        rdy, _, _ = _select_mod.select([fd], [], [], 0.25)
        if not rdy:
            break
        c = os.read(fd, 1)
        resp += c
        if c == b"R":
            break
    m = re.search(rb"\x1b\[(\d+);\d+R", resp)
    return int(m.group(1)) if m else None


def _visible_rows():
    try:
        return max(3, os.get_terminal_size().lines - 4)
    except OSError:
        return 15


def select(items, render, filter_key, quote, subhead, hint):
    """Sélecteur interactif : renvoie l'item choisi, None si annulé, NOTTY si pas de TTY.

    En-tête sur 3 lignes : `quote` (réplique, seule), ligne vide, puis `subhead` + compteur.
    `render(item, selected)` -> ligne affichée ; `filter_key(item)` -> texte filtrable."""
    try:
        fh = open("/dev/tty", "r+b", buffering=0)
    except OSError:
        return NOTTY
    fd = fh.fileno()
    if not os.isatty(fd):
        fh.close()
        return NOTTY

    old = termios.tcgetattr(fd)
    query, idx, top, prev_lines = "", 0, 0, 0
    rows = _visible_rows()
    start_row, mouse = None, False

    def write(s):
        os.write(fd, s.encode())

    def goto_top():
        if start_row is not None:
            write("\x1b[%d;1H" % start_row)
        elif prev_lines:
            write("\r\x1b[%dA" % prev_lines)

    try:
        tty.setraw(fd)
        write("\x1b[?25l")
        start_row = _cursor_row(fd)
        if start_row is not None:
            height = 5 + min(len(items), rows)
            try:
                screen = os.get_terminal_size().lines
            except OSError:
                screen = 24
            if start_row - 1 + height > screen:  # réserve la place (évite un scroll qui casse l'ancre)
                scroll = start_row - 1 + height - screen
                write("\n" * scroll)
                start_row -= scroll
            write("\x1b[?1000h\x1b[?1006h")  # reporting souris (clic + SGR)
            mouse = True
        while True:
            q = query.lower()
            shown = [it for it in items if q in filter_key(it).lower()] if q else list(items)
            idx = min(idx, max(0, len(shown) - 1))
            if idx < top:
                top = idx
            elif idx >= top + rows:
                top = idx - rows + 1
            view = shown[top:top + rows]

            goto_top()
            write("\x1b[J")

            count_label = "%d/%d" % (len(shown), len(items))
            head = [quote, "", "%s  %s(%s)%s" % (subhead, DIM, count_label, RESET)]
            lines = list(head)
            for i, it in enumerate(view):
                selected = (top + i) == idx
                marker = "%s▶%s " % (BRIGHT, RESET) if selected else "  "
                lines.append(marker + render(it, selected))
            footer = "%s%s%s" % (DIM, hint, RESET)
            if query:
                footer += "   %sfiltre:%s %s%s%s" % (DIM, RESET, GREEN, query, RESET)
            lines.append("")
            lines.append(footer)

            write("".join(line + "\x1b[K\r\n" for line in lines))
            prev_lines = len(lines)

            key = _read_key(fd)
            if key in ("ctrl-c", "esc", "eof"):
                return None
            if key == "enter":
                if shown:
                    return shown[idx]
                continue
            if key == "up":
                idx = max(0, idx - 1)
            elif key == "down":
                idx = min(len(shown) - 1, idx + 1) if shown else 0
            elif key == "backspace":
                query, idx = query[:-1], 0
            elif isinstance(key, tuple) and key[0] == "wheel":
                if shown:
                    idx = min(len(shown) - 1, max(0, idx + key[1]))
            elif isinstance(key, tuple) and key[0] == "click" and start_row is not None:
                view_index = key[1] - start_row - len(head)  # ligne écran -> index item
                if 0 <= view_index < len(view):
                    return shown[top + view_index]
            elif isinstance(key, str) and len(key) == 1 and key.isprintable():
                query, idx = query + key, 0
    finally:
        if mouse:
            write("\x1b[?1000l\x1b[?1006l")
        goto_top()
        write("\x1b[J\x1b[?25h")
        termios.tcsetattr(fd, termios.TCSADRAIN, old)
        fh.close()


# ── Fallbacks numérotés (pas de TTY interactif) ─────────────────────────────

def choose_repo_fallback(repos):
    sys.stderr.write("\n%sNouvelle session%s — choisis un repo :\n\n" % (BRIGHT, RESET))
    sys.stderr.write("   %s0%s) ~  %s(dossier user — défaut)%s\n" % (BRIGHT, RESET, DIM, RESET))
    for i, r in enumerate(repos, 1):
        sys.stderr.write("  %3d) %s\n" % (i, r))
    while True:
        try:
            raw = input("\n%sredpill%s > repo # ou nom (Entrée = user) : " % (GREEN, RESET)).strip()
        except (EOFError, KeyboardInterrupt):
            return HOME
        if raw in ("", "0"):
            return HOME
        if raw.isdigit():
            i = int(raw)
            if 1 <= i <= len(repos):
                return os.path.join(REPOS, repos[i - 1])
            sys.stderr.write(DIM + "  numéro hors plage\n" + RESET)
            continue
        hits = [r for r in repos if raw.lower() in r.lower()]
        if len(hits) == 1:
            return os.path.join(REPOS, hits[0])
        sys.stderr.write(DIM + ("  aucun repo ne correspond\n" if not hits
                                else "  plusieurs : " + ", ".join(hits) + "\n") + RESET)


# ── Sélecteurs ──────────────────────────────────────────────────────────────

USER_HOME = {"_user": True}


def choose_repo():
    """Sélecteur de repo (dossier user par défaut). Renvoie le chemin cible."""
    repos = list_repos()
    items = [USER_HOME] + [{"repo": r} for r in repos]

    def render(it, selected):
        if it is USER_HOME:
            return "~  %s(dossier user — défaut)%s" % (DIM, RESET)
        return "%s%s%s" % (BRIGHT if selected else "", it["repo"], RESET if selected else "")

    def fkey(it):
        return "~ user home défaut default" if it is USER_HOME else it["repo"]

    quote = '%s"Guns. Lots of guns."%s' % (GREEN, RESET)
    subhead = "%schoisis un repo%s" % (BRIGHT, RESET)
    hint = "↑↓ · tape pour filtrer · clic · ⏎ · Échap = user"
    choice = select(items, render, fkey, quote, subhead, hint)
    if choice is NOTTY:
        return choose_repo_fallback(repos)
    if choice is None or choice is USER_HOME:
        return HOME
    return os.path.join(REPOS, choice["repo"])


def ask_name():
    """Demande un nom de session optionnel (renommera la fenêtre et sera passé à claude).

    Renvoie le nom saisi ou None (Entrée = nom auto d'après le sujet, comportement historique)."""
    sys.stderr.write("\n%s\"There is no spoon.\"%s %snomme ta session%s\n" % (GREEN, RESET, BRIGHT, RESET))
    try:
        raw = input("%sredpill%s > nom (Entrée = auto) : " % (GREEN, RESET)).strip()
    except (EOFError, KeyboardInterrupt):
        return None
    return raw or None


def matrix_argv(name):
    """Argv du lanceur matrix pour une nouvelle session, avec nom optionnel."""
    return ["matrix", "--name", name] if name else ["matrix"]


def new_session():
    target = choose_repo()
    name = ask_name()
    try:
        os.chdir(target)
    except OSError:
        os.chdir(HOME)
    os.execvp("matrix", matrix_argv(name))


def resume_session(s):
    if s.get("cwd") and os.path.isdir(s["cwd"]):
        os.chdir(s["cwd"])
    os.execvp("matrix", ["matrix", "resume", s["sid"]])


def main():
    sessions = m.list_sessions()
    if not sessions:
        return new_session()
    now = time.time()
    new_entry = {"_new": True}
    items = [new_entry] + sessions

    def render(it, selected):
        if it is new_entry:
            return "%s＋ nouvelle session…%s" % (BRIGHT, RESET)
        agent = it.get("agent") or "—"
        cols = (trunc(it["project"], 14), trunc(agent, 14),
                trunc(it["label"], 30), fmt_age(now - it["mtime"]))
        if selected:
            return "%s%-14s %-14s %-30s (%s)%s" % (BRIGHT, cols[0], cols[1], cols[2], cols[3], RESET)
        return "%-14s %s%-14s%s %-30s %s(%s)%s" % (
            cols[0], GREEN, cols[1], RESET, cols[2], DIM, cols[3], RESET)

    def fkey(it):
        if it is new_entry:
            return "nouvelle session new nouveau"
        return " ".join([it.get("project") or "", it.get("agent") or "", it.get("label") or ""])

    quote = "%sThe Matrix has you…%s" % (GREEN, RESET)
    subhead = "%schoisis ta réalité%s" % (BRIGHT, RESET)
    hint = "↑↓ · tape pour filtrer · clic · ⏎ · Échap = nouvelle"
    choice = select(items, render, fkey, quote, subhead, hint)

    if choice is NOTTY:
        return main_fallback(sessions, now)
    if choice is None or choice is new_entry:
        return new_session()
    resume_session(choice)


def main_fallback(sessions, now):
    sys.stderr.write("\n%sThe Matrix has you...%s  choisis ta réalité :\n\n" % (GREEN, RESET))
    sys.stderr.write("%s↻ Reprendre une session :%s\n" % (BRIGHT, RESET))
    for i, s in enumerate(sessions, 1):
        agent = s.get("agent") or "—"
        sys.stderr.write("  %2d) %-14s %s%-14s%s %-30s %s(%s)%s\n" % (
            i, trunc(s["project"], 14), GREEN, trunc(agent, 14), RESET,
            trunc(s["label"], 30), DIM, fmt_age(now - s["mtime"]), RESET))
    sys.stderr.write("\n  %sn%s) nouvelle session (choisir un repo)\n" % (BRIGHT, RESET))
    try:
        choice = input("\n%sredpill%s > numéro (reprise) ou n / Entrée (nouveau) : " % (GREEN, RESET)).strip()
    except (EOFError, KeyboardInterrupt):
        choice = ""
    if choice.isdigit() and 1 <= int(choice) <= len(sessions):
        resume_session(sessions[int(choice) - 1])
    new_session()


if __name__ == "__main__":
    main()
