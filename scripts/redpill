#!/usr/bin/env python3
"""redpill — choisis ta réalité : reprendre une session Claude récente, ou en démarrer une.

Menu au lancement (sélecteur interactif : ↑↓ pour naviguer, tape pour filtrer,
Entrée pour valider) :
  - liste des sessions récentes → sélection directe = reprise personnifiée
    (`matrix resume <uuid>` dans le dossier de la session) ;
  - entrée « ＋ nouvelle session… » = wizard nouvelle session (repo → nom) ;
  - Échap sur le menu = nouvelle session directe dans le dossier courant.

Le wizard « nouvelle session » affiche un fil d'Ariane des choix précédents et
Échap y ramène à l'étape précédente (nom → repo → menu). Chaque écran porte une
bannière (logo figlet MATRIX + pluie de code katakana) calée en haut à droite.

Sans TTY interactif (sortie redirigée), on retombe sur un menu numéroté simple.
"""
import os
import re
import select as _select_mod
import sys
import termios
import time
import tty

sys.path.insert(0, os.path.dirname(os.path.abspath(__file__)))
import matrix_lib as m
import matrix_logo as logo

REPOS = os.path.expanduser("~/Arx/repositories")
HOME = os.path.expanduser("~")
GREEN, BRIGHT, DIM, RESET = "\033[32m", "\033[92m", "\033[2m", "\033[0m"
CRUMB_BG = [28, 34, 40, 46]  # fil d'Ariane : vert sombre → vif (palette 256 couleurs), une teinte par étape
ARROW = "%s ▸ %s" % (BRIGHT, RESET)  # flèche de progression entre les étapes

NOTTY = object()  # sentinelle : pas de terminal interactif -> fallback appelant
BACK = object()   # sentinelle : Échap -> retour à l'étape précédente

TOP_ROWS = max(8, logo.BANNER_ROWS)  # hauteur de la zone d'en-tête


# ── Bannière : logo figlet + pluie (module partagé matrix_logo) ─────────────

def build_top_region(crumb_line, quote, subhead_line, width):
    """Zone d'en-tête : texte à gauche (2 marges + réplique/fil d'Ariane/sous-titre
    espacés), bannière logo+pluie calée en haut à droite."""
    left = ["", "", quote, "", crumb_line, "", "", subhead_line]
    return logo.overlay_right(left, width)


def _chip(label, i):
    """Étape du fil d'Ariane : teinte de fond selon la position (dégradé de progression)."""
    bg = CRUMB_BG[min(i, len(CRUMB_BG) - 1)]
    fg = 15 if bg <= 28 else 0  # blanc sur vert sombre, noir sur vert vif
    return "\033[38;5;%d;48;5;%dm %s \033[0m" % (fg, bg, label)


def _crumbs_line(crumbs):
    if not crumbs:
        return ""
    return ARROW.join(_chip(c, i) for i, c in enumerate(crumbs)) + "%s ▸%s" % (BRIGHT, RESET)


# ── Sélecteur interactif (mode raw, stdlib) ─────────────────────────────────

def fmt_age(sec):
    sec = int(sec)
    if sec < 60:
        return "%ds" % sec
    if sec < 3600:
        return "%dm" % (sec // 60)
    if sec < 86400:
        return "%dh" % (sec // 3600)
    return "%dd" % (sec // 86400)


def trunc(s, n):
    s = s or ""
    return s if len(s) <= n else s[:n - 1] + "…"


def list_repos():
    try:
        return sorted(d for d in os.listdir(REPOS)
                      if os.path.isdir(os.path.join(REPOS, d)) and not d.startswith("."))
    except OSError:
        return []


def _parse_mouse(seq):
    """Séquence SGR `<b;col;ligneM/m` -> ('click', ligne) | ('wheel', ±1) | 'other'."""
    mt = re.match(rb"<(\d+);(\d+);(\d+)([Mm])", seq)
    if not mt:
        return "other"
    button, row, final = int(mt.group(1)), int(mt.group(3)), mt.group(4)
    if button & 64:
        return "wheel", (1 if button & 1 else -1)
    if (button & 3) == 0 and final == b"M":
        return "click", row
    return "other"


def _read_key(fd):
    """Lit une touche logique sur un fd en mode raw. Renvoie un token, un tuple ou un caractère."""
    ch = os.read(fd, 1)
    if not ch:
        return "eof"
    if ch == b"\x03":
        return "ctrl-c"
    if ch in (b"\r", b"\n"):
        return "enter"
    if ch in (b"\x7f", b"\x08"):
        return "backspace"
    if ch == b"\x0e":  # Ctrl-N
        return "down"
    if ch == b"\x10":  # Ctrl-P
        return "up"
    if ch == b"\x1b":
        rdy, _, _ = _select_mod.select([fd], [], [], 0.02)
        if not rdy:
            return "esc"
        if os.read(fd, 1) != b"[":
            return "other"
        seq = b""
        while True:
            rdy, _, _ = _select_mod.select([fd], [], [], 0.05)
            if not rdy:
                break
            c = os.read(fd, 1)
            seq += c
            if 0x40 <= c[0] <= 0x7e:  # octet final d'une séquence CSI
                break
        if seq in (b"A", b"OA"):
            return "up"
        if seq in (b"B", b"OB"):
            return "down"
        if seq[:1] == b"<":
            return _parse_mouse(seq)
        return "other"
    try:
        dec = ch.decode("utf-8")
        return dec if dec.isprintable() else "other"
    except UnicodeDecodeError:
        return "other"


def _cursor_row(fd):
    """Interroge la position du curseur (DSR) et renvoie sa ligne (1-based) ou None."""
    os.write(fd, b"\x1b[6n")
    resp = b""
    while True:
        rdy, _, _ = _select_mod.select([fd], [], [], 0.25)
        if not rdy:
            break
        c = os.read(fd, 1)
        resp += c
        if c == b"R":
            break
    mt = re.search(rb"\x1b\[(\d+);\d+R", resp)
    return int(mt.group(1)) if mt else None


def _reserve(fd, need):
    """Renvoie la ligne d'ancrage après avoir garanti `need` lignes sous le curseur."""
    row = _cursor_row(fd)
    if row is None:
        return None
    try:
        screen = os.get_terminal_size().lines
    except OSError:
        screen = 24
    if row - 1 + need > screen:
        scroll = row - 1 + need - screen
        os.write(fd, ("\n" * scroll).encode())
        row -= scroll
    return row


def _term_width():
    try:
        return os.get_terminal_size().columns
    except OSError:
        return 80


def _visible_rows():
    try:
        return max(3, os.get_terminal_size().lines - TOP_ROWS - 5)
    except OSError:
        return 12


def select(items, render, filter_key, crumbs, quote, subhead, hint, detail=None):
    """Sélecteur interactif : renvoie l'item choisi, BACK si Échap, None si Ctrl-C,
    NOTTY si pas de TTY.

    `crumbs` = fil d'Ariane (segments joints par ` › `) affiché sous la réplique.
    `render(item, selected)` -> ligne affichée ; `filter_key(item)` -> texte filtrable.
    `detail(item)` -> ligne de détail (déjà stylée) affichée sous la liste pour l'item
    en surbrillance, ou None pour n'en afficher aucune."""
    try:
        fh = open("/dev/tty", "r+b", buffering=0)
    except OSError:
        return NOTTY
    fd = fh.fileno()
    if not os.isatty(fd):
        fh.close()
        return NOTTY

    old = termios.tcgetattr(fd)
    query, idx, top, prev_lines = "", 0, 0, 0
    rows = _visible_rows()
    start_row, mouse = None, False
    crumb_line = _crumbs_line(crumbs)

    def write(s):
        os.write(fd, s.encode())

    def goto_top():
        if start_row is not None:
            write("\x1b[%d;1H" % start_row)
        elif prev_lines:
            write("\r\x1b[%dA" % prev_lines)

    try:
        tty.setraw(fd)
        write("\x1b[?25l")
        start_row = _reserve(fd, TOP_ROWS + 4 + min(len(items), rows))
        if start_row is not None:
            write("\x1b[?1000h\x1b[?1006h")  # reporting souris (clic + SGR)
            mouse = True
        while True:
            q = query.lower()
            shown = [it for it in items if q in filter_key(it).lower()] if q else list(items)
            idx = min(idx, max(0, len(shown) - 1))
            if idx < top:
                top = idx
            elif idx >= top + rows:
                top = idx - rows + 1
            view = shown[top:top + rows]

            goto_top()
            write("\x1b[J")

            count_label = "%d/%d" % (len(shown), len(items))
            subhead_line = "%s  %s(%s)%s" % (subhead, DIM, count_label, RESET)
            lines = build_top_region(crumb_line, quote, subhead_line, _term_width())
            for i, it in enumerate(view):
                selected = (top + i) == idx
                marker = "%s▶%s " % (BRIGHT, RESET) if selected else "  "
                lines.append(marker + render(it, selected))
            footer = "%s%s%s" % (DIM, hint, RESET)
            if query:
                footer += "   %sfiltre:%s %s%s%s" % (DIM, RESET, GREEN, query, RESET)
            lines.append("")
            if detail is not None and shown:
                dl = detail(shown[idx])
                if dl:
                    lines.append(dl)
                    lines.append("")
            lines.append(footer)

            write("".join(line + "\x1b[K\r\n" for line in lines))
            prev_lines = len(lines)

            key = _read_key(fd)
            if key == "esc":
                return BACK
            if key in ("ctrl-c", "eof"):
                return None
            if key == "enter":
                if shown:
                    return shown[idx]
                continue
            if key == "up":
                idx = max(0, idx - 1)
            elif key == "down":
                idx = min(len(shown) - 1, idx + 1) if shown else 0
            elif key == "backspace":
                query, idx = query[:-1], 0
            elif isinstance(key, tuple) and key[0] == "wheel":
                if shown:
                    idx = min(len(shown) - 1, max(0, idx + key[1]))
            elif isinstance(key, tuple) and key[0] == "click" and start_row is not None:
                view_index = key[1] - start_row - TOP_ROWS  # ligne écran -> index item
                if 0 <= view_index < len(view):
                    return shown[top + view_index]
            elif isinstance(key, str) and len(key) == 1 and key.isprintable():
                query, idx = query + key, 0
    finally:
        if mouse:
            write("\x1b[?1000l\x1b[?1006l")
        goto_top()
        write("\x1b[J\x1b[?25h")
        termios.tcsetattr(fd, termios.TCSADRAIN, old)
        fh.close()


def prompt_text(crumbs, quote, subhead, hint):
    """Champ de saisie plein écran (même bannière que `select`).

    Renvoie le texte saisi (`""` si vide), BACK si Échap, None si Ctrl-C, NOTTY si pas de TTY."""
    try:
        fh = open("/dev/tty", "r+b", buffering=0)
    except OSError:
        return NOTTY
    fd = fh.fileno()
    if not os.isatty(fd):
        fh.close()
        return NOTTY

    old = termios.tcgetattr(fd)
    buf, start_row = "", None
    crumb_line = _crumbs_line(crumbs)

    def write(s):
        os.write(fd, s.encode())

    try:
        tty.setraw(fd)
        write("\x1b[?25l")
        start_row = _reserve(fd, TOP_ROWS + 4)
        while True:
            if start_row is not None:
                write("\x1b[%d;1H" % start_row)
            write("\x1b[J")
            subhead_line = "%s%s%s" % (BRIGHT, subhead, RESET)
            lines = build_top_region(crumb_line, quote, subhead_line, _term_width())
            cursor = "\x1b[7m \x1b[0m"
            lines.append("")
            lines.append("%sredpill%s > %s%s%s%s" % (GREEN, RESET, GREEN, buf, RESET, cursor))
            lines.append("")
            lines.append("%s%s%s" % (DIM, hint, RESET))
            write("".join(line + "\x1b[K\r\n" for line in lines))

            key = _read_key(fd)
            if key == "esc":
                return BACK
            if key in ("ctrl-c", "eof"):
                return None
            if key == "enter":
                return buf.strip()
            if key == "backspace":
                buf = buf[:-1]
            elif isinstance(key, str) and len(key) == 1 and key.isprintable():
                buf += key
    finally:
        if start_row is not None:
            write("\x1b[%d;1H" % start_row)
        write("\x1b[J\x1b[?25h")
        termios.tcsetattr(fd, termios.TCSADRAIN, old)
        fh.close()


# ── Fallbacks numérotés (pas de TTY interactif) ─────────────────────────────

def choose_repo_fallback(repos):
    sys.stderr.write("\n%sNouvelle session%s — choisis un repo :\n\n" % (BRIGHT, RESET))
    sys.stderr.write("   %s0%s) ~  %s(dossier user — défaut)%s\n" % (BRIGHT, RESET, DIM, RESET))
    for i, r in enumerate(repos, 1):
        sys.stderr.write("  %3d) %s\n" % (i, r))
    while True:
        try:
            raw = input("\n%sredpill%s > repo # ou nom (Entrée = user) : " % (GREEN, RESET)).strip()
        except (EOFError, KeyboardInterrupt):
            return HOME
        if raw in ("", "0"):
            return HOME
        if raw.isdigit():
            i = int(raw)
            if 1 <= i <= len(repos):
                return os.path.join(REPOS, repos[i - 1])
            sys.stderr.write(DIM + "  numéro hors plage\n" + RESET)
            continue
        hits = [r for r in repos if raw.lower() in r.lower()]
        if len(hits) == 1:
            return os.path.join(REPOS, hits[0])
        sys.stderr.write(DIM + ("  aucun repo ne correspond\n" if not hits
                                else "  plusieurs : " + ", ".join(hits) + "\n") + RESET)


def ask_name_fallback():
    sys.stderr.write("\n%s\"There is no spoon.\"%s %snomme ta session%s\n" % (GREEN, RESET, BRIGHT, RESET))
    try:
        raw = input("%sredpill%s > nom (Entrée = auto) : " % (GREEN, RESET)).strip()
    except (EOFError, KeyboardInterrupt):
        return None
    return raw or None


# ── Sélecteurs ──────────────────────────────────────────────────────────────

USER_HOME = {"_user": True}


def choose_repo(crumbs):
    """Sélecteur de repo (dossier user via l'entrée « ~ »). Renvoie un chemin ou BACK."""
    repos = list_repos()
    items = [USER_HOME] + [{"repo": r} for r in repos]

    def render(it, selected):
        if it is USER_HOME:
            return "~  %s(dossier user — défaut)%s" % (DIM, RESET)
        return "%s%s%s" % (BRIGHT if selected else "", it["repo"], RESET if selected else "")

    def fkey(it):
        return "~ user home défaut default" if it is USER_HOME else it["repo"]

    quote = '%s"Guns. Lots of guns."%s' % (GREEN, RESET)
    subhead = "%schoisis un repo%s" % (BRIGHT, RESET)
    hint = "↑↓ · tape pour filtrer · clic · ⏎ · Échap = retour"
    choice = select(items, render, fkey, crumbs, quote, subhead, hint)
    if choice is NOTTY:
        return choose_repo_fallback(repos)
    if choice is BACK:
        return BACK
    if choice is None:
        sys.exit(0)
    if choice is USER_HOME:
        return HOME
    return os.path.join(REPOS, choice["repo"])


def ask_name(crumbs):
    """Demande un nom de session optionnel. Renvoie le nom, None (auto) ou BACK."""
    quote = '%s"There is no spoon."%s' % (GREEN, RESET)
    subhead = "nomme ta session"
    hint = "⏎ = valider · vide = nom auto · Échap = retour"
    res = prompt_text(crumbs, quote, subhead, hint)
    if res is NOTTY:
        return ask_name_fallback()
    if res is BACK:
        return BACK
    if res is None:
        sys.exit(0)
    return res or None


def matrix_argv(name):
    """Argv du lanceur matrix pour une nouvelle session, avec nom optionnel."""
    return ["matrix", "--name", name] if name else ["matrix"]


def new_session_wizard():
    """Wizard repo → nom. Renvoie (chemin_cible, nom) à lancer, ou BACK vers le menu."""
    repo = None
    step = 0
    while True:
        if step == 0:
            res = choose_repo(["Nouvelle session"])
            if res is BACK:
                return BACK
            repo = res
            step = 1
        else:
            crumb_repo = "~" if repo == HOME else os.path.basename(repo)
            res = ask_name(["Nouvelle session", crumb_repo])
            if res is BACK:
                step = 0
                continue
            return repo, res


def launch_new(target, name):
    try:
        os.chdir(target)
    except OSError:
        os.chdir(HOME)
    os.execvp("matrix", matrix_argv(name))


def launch_new_cwd():
    """Nouvelle session dans le dossier courant, sans étape de choix."""
    os.execvp("matrix", ["matrix"])


def resume_session(s):
    if s.get("cwd") and os.path.isdir(s["cwd"]):
        os.chdir(s["cwd"])
    os.execvp("matrix", ["matrix", "resume", s["sid"]])


def main():
    sessions = m.list_sessions()
    if not sessions:
        res = new_session_wizard()
        if res is BACK:
            launch_new_cwd()
        return launch_new(res[0], res[1])

    new_entry = {"_new": True}
    while True:
        now = time.time()
        paused = [s for s in sessions if s.get("paused")]
        wake_entry = {"_wake": True, "_count": len(paused)}
        sessions_sorted = paused + [s for s in sessions if not s.get("paused")]
        items = ([wake_entry] if paused else []) + [new_entry] + sessions_sorted

        label_w = max(30, _term_width() - 42)

        def render(it, selected):
            if it.get("_wake"):
                return "%s⏰ Réveiller les %d sessions en pause…%s" % (BRIGHT, it["_count"], RESET)
            if it is new_entry:
                return "%s＋ nouvelle session…%s" % (BRIGHT, RESET)
            proj = ("‖ " if it.get("paused") else "") + it["project"]
            agent = it.get("agent") or "—"
            cols = (trunc(proj, 14), trunc(agent, 14),
                    trunc(it["label"], label_w), fmt_age(now - it["mtime"]))
            if selected:
                return "%s%-14s %-14s %-*s (%s)%s" % (BRIGHT, cols[0], cols[1], label_w, cols[2], cols[3], RESET)
            return "%-14s %s%-14s%s %-*s %s(%s)%s" % (
                cols[0], GREEN, cols[1], RESET, label_w, cols[2], DIM, cols[3], RESET)

        def fkey(it):
            if it.get("_wake"):
                return "wake reveiller pause"
            if it is new_entry:
                return "nouvelle session new nouveau"
            return " ".join([it.get("project") or "", it.get("agent") or "", it.get("label") or ""])

        def detail(it):
            if it.get("_wake"):
                return None
            if it is new_entry:
                return None
            bits = ["%s%s%s" % (BRIGHT, it["label"], RESET)]
            cwd = it.get("cwd")
            if cwd:
                short = "~" + cwd[len(HOME):] if cwd.startswith(HOME) else cwd
                bits.append("%s%s%s" % (GREEN, short, RESET))
            if it.get("agent"):
                bits.append(it["agent"])
            bits.append("%sil y a %s%s" % (DIM, fmt_age(now - it["mtime"]), RESET))
            sep = "%s  ·  %s" % (DIM, RESET)
            return "   " + sep.join(bits)

        quote = "%sThe Matrix has you…%s" % (GREEN, RESET)
        subhead = "%schoisis ta réalité%s" % (BRIGHT, RESET)
        hint = "↑↓ · tape pour filtrer · clic · ⏎ · Échap = session ici"
        choice = select(items, render, fkey, [], quote, subhead, hint, detail)

        if choice is NOTTY:
            return main_fallback(sessions, now)
        if choice is None:
            return
        if choice is BACK:
            return launch_new_cwd()
        if choice is new_entry:
            res = new_session_wizard()
            if res is BACK:
                continue
            return launch_new(res[0], res[1])
        if choice.get("_wake"):
            for p in m.paused_sessions():
                cwd = p.get("cwd")
                try:
                    import subprocess
                    subprocess.Popen(["kitty", "--directory", cwd or HOME,
                                      "zsh", "-ic", "matrix resume %s" % p["sid"]],
                                     start_new_session=True,
                                     stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
                    m.clear_paused(p["sid"])
                except Exception:
                    pass
            return
        return resume_session(choice)


def main_fallback(sessions, now):
    sys.stderr.write("\n%sThe Matrix has you...%s  choisis ta réalité :\n\n" % (GREEN, RESET))
    sys.stderr.write("%s↻ Reprendre une session :%s\n" % (BRIGHT, RESET))
    for i, s in enumerate(sessions, 1):
        agent = s.get("agent") or "—"
        sys.stderr.write("  %2d) %-14s %s%-14s%s %-30s %s(%s)%s\n" % (
            i, trunc(s["project"], 14), GREEN, trunc(agent, 14), RESET,
            trunc(s["label"], 30), DIM, fmt_age(now - s["mtime"]), RESET))
    sys.stderr.write("\n  %sn%s) nouvelle session (choisir un repo)\n" % (BRIGHT, RESET))
    try:
        choice = input("\n%sredpill%s > numéro (reprise) ou n / Entrée (nouveau) : " % (GREEN, RESET)).strip()
    except (EOFError, KeyboardInterrupt):
        choice = ""
    if choice.isdigit() and 1 <= int(choice) <= len(sessions):
        resume_session(sessions[int(choice) - 1])
    launch_new(choose_repo_fallback(list_repos()), ask_name_fallback())


if __name__ == "__main__":
    main()
