#!/usr/bin/env python3
"""matrix / redpill — lance une session Claude personnifiée (The Matrix).

Usage :
  matrix                     # personnifie le repo courant (cwd), lance claude
  matrix [args claude...]    # idem, en passant des options à claude
  matrix resume <uuid>       # reprend une session en conservant son persona

Assigne un persona (Agent Smith…), route vers le salon Discord du repo (via le
webhook, dans notify-event.py), enregistre KITTY_WINDOW_ID + KITTY_LISTEN_ON
pour le focus depuis ccs, puis exec claude. Le nom d'agent est passé à
`claude --name` → il remonte au titre de la fenêtre (dynamique, non figé).

MATRIX_DRY_RUN=1 : affiche ce qui serait fait sans lancer claude (test).
"""
import os
import subprocess
import sys
import time
import uuid

sys.path.insert(0, os.path.dirname(os.path.abspath(__file__)))
import matrix_lib as m

GREEN = "\033[32m"
BRIGHT = "\033[92m"
RESET = "\033[0m"


def extract_name(args):
    """Valeur d'un `--name`/`-n`/`--name=` dans les args passthrough, ou None."""
    i = 0
    while i < len(args):
        a = args[i]
        if a in ("--name", "-n") and i + 1 < len(args):
            return args[i + 1]
        if a.startswith("--name="):
            return a.split("=", 1)[1]
        i += 1
    return None


def kitty_extra():
    out = {}
    for key, env in (("kitty_window_id", "KITTY_WINDOW_ID"),
                     ("kitty_listen_on", "KITTY_LISTEN_ON")):
        val = os.environ.get(env)
        if val:
            out[key] = val
    return out


def intro(agent):
    sys.stderr.write(f"\n{GREEN}The Matrix has you...{RESET}\n")
    sys.stderr.write(f"{BRIGHT}You are now {agent}.{RESET}\n\n")
    sys.stderr.flush()
    if sys.stderr.isatty():
        time.sleep(0.8)


def pin_window_title(title):
    """Fixe le titre de la fenêtre kitty (permanent : Claude ne l'écrase pas)."""
    wid = os.environ.get("KITTY_WINDOW_ID")
    if not wid:
        return
    try:
        subprocess.run(["kitty", "@", "set-window-title", "--match", "id:" + wid, title],
                       timeout=5, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
    except Exception:
        pass


def main():
    argv = sys.argv[1:]
    resume_uuid = None
    if argv and argv[0] == "resume":
        if len(argv) < 2:
            sys.exit("usage: matrix resume <uuid>")
        resume_uuid = argv[1]
        passthrough = argv[2:]
    else:
        passthrough = argv

    cwd = os.getcwd()
    sid = resume_uuid or str(uuid.uuid4())

    # Reprise : conserver le persona déjà attribué à cet uuid s'il existe.
    keep_agent = None
    if resume_uuid:
        old = m.get(resume_uuid)
        keep_agent = old.get("agent") if old else None

    entry = m.register(sid, cwd, agent=keep_agent, **kitty_extra())
    agent = entry["agent"] if entry else "Nobody"

    # On ne nomme jamais la session d'après le persona (sinon le picker /resume liste
    # des « Agent Smith » indistincts). Un --name explicite (fourni par redpill) est en
    # revanche honoré : passé à claude via passthrough et repris pour le titre de fenêtre.
    if resume_uuid:
        claude_args = ["claude", "--resume", sid] + passthrough
    else:
        claude_args = ["claude", "--session-id", sid] + passthrough

    label = extract_name(passthrough) or m.session_label(sid, cwd)
    win_title = ("%s — %s" % (agent, label)) if label else agent

    if os.environ.get("MATRIX_DRY_RUN"):
        print(f"agent   : {agent}")
        print(f"salon   : #{entry['channel'] if entry else '?'}")
        print(f"window  : {entry.get('kitty_window_id') if entry else '-'}")
        print(f"titre   : {win_title}")
        print(f"cmd     : {' '.join(claude_args)}")
        return

    pin_window_title(win_title)
    intro(agent)
    try:
        os.execvp("claude", claude_args)
    except OSError as err:
        sys.exit(f"matrix: impossible de lancer claude ({err})")


if __name__ == "__main__":
    main()
