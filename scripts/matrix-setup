#!/usr/bin/env python3
"""matrix-setup — prépare Discord pour The Matrix (idempotent).

Découvre les repos sous ~/Arx/repositories et crée, dans le serveur "The Matrix" :
- #the-construct : salon système (hors-repo / défaut) ;
- un salon texte + webhook par repo principal, rangés sous la catégorie "repos" ;
- un repoMap routant chaque worktree vers le salon de son repo parent.
Écrit ~/.claude/channels/discord/matrix/config.json (chmod 600).

Prérequis : le bot doit être membre de "The Matrix" avec les permissions
Manage Channels + Manage Webhooks. Re-exécutable sans doublon.
"""
import json
import os
import sys
import time
import urllib.error
import urllib.request

DISCORD = "https://discord.com/api/v10"
CHANNELS_DIR = os.path.expanduser("~/.claude/channels/discord")
ENV = os.path.join(CHANNELS_DIR, ".env")
MATRIX_DIR = os.path.join(CHANNELS_DIR, "matrix")
CONFIG = os.path.join(MATRIX_DIR, "config.json")
REPOS_ROOT = os.path.expanduser("~/Arx/repositories")

GUILD_NAME = "The Matrix"
WEBHOOK_NAME = "matrix"
DEFAULT_CHANNEL = "the-construct"
REPOS_CATEGORY = "repos"
USER_AGENT = "MatrixSetup (https://arxcf.com, 1.0)"

# Pool ordonné de personas (Agents canoniques puis programmes du Système).
PERSONAS = [
    "Agent Smith", "Agent Brown", "Agent Jones", "Agent Johnson",
    "Agent Jackson", "Agent Thompson", "Agent White", "The Oracle", "The Architect",
    "The Merovingian", "Seraph", "The Keymaker", "Persephone",
    "The Twins", "The Trainman", "Sati",
]


def read_token():
    with open(ENV) as fh:
        for line in fh:
            if line.startswith("DISCORD_BOT_TOKEN="):
                return line.split("=", 1)[1].strip()
    sys.exit(f"DISCORD_BOT_TOKEN introuvable dans {ENV}")


def api(method, path, token, body=None, _try=0):
    data = json.dumps(body).encode() if body is not None else None
    req = urllib.request.Request(
        DISCORD + path, data=data, method=method,
        headers={"Authorization": f"Bot {token}", "Content-Type": "application/json",
                 "User-Agent": USER_AGENT})
    try:
        with urllib.request.urlopen(req) as resp:
            return json.load(resp)
    except urllib.error.HTTPError as err:
        if err.code == 429 and _try < 6:  # rate limit : on attend et on réessaie
            try:
                retry = float(json.loads(err.read()).get("retry_after", 1))
            except Exception:
                retry = 1.0
            time.sleep(retry + 0.5)
            return api(method, path, token, body, _try + 1)
        sys.exit(f"Discord API {method} {path} -> {err.code}: {err.read().decode()}")


def worktree_parent(git_file):
    """Renvoie le nom du repo parent d'un worktree (lu dans son fichier .git)."""
    try:
        with open(git_file) as fh:
            line = fh.read().strip()
    except OSError:
        return None
    marker = "/.git/worktrees/"
    if line.startswith("gitdir:") and marker in line:
        return os.path.basename(line.split(":", 1)[1].strip().split(marker)[0])
    return None


def discover():
    """(liste des repos principaux triés, repoMap worktree -> repo parent)."""
    repos, repo_map = [], {}
    try:
        names = sorted(os.listdir(REPOS_ROOT))
    except OSError:
        return repos, repo_map
    for name in names:
        git = os.path.join(REPOS_ROOT, name, ".git")
        if os.path.isdir(git):
            repos.append(name)
        elif os.path.isfile(git):
            parent = worktree_parent(git)
            if parent:
                repo_map[name] = parent
    return repos, repo_map


def find_guild(token):
    for guild in api("GET", "/users/@me/guilds", token):
        if guild["name"] == GUILD_NAME:
            return guild["id"]
    sys.exit(f'Serveur "{GUILD_NAME}" introuvable. Crée-le et invite le bot, puis relance.')


def ensure_channel(token, guild_id, existing, name, ctype=0, parent_id=None):
    """Renvoie (channel, créé?). Range sous parent_id si fourni (déplace au besoin)."""
    channel = existing.get((name, ctype))
    if channel is None:
        body = {"name": name, "type": ctype}
        if parent_id:
            body["parent_id"] = parent_id
        return api("POST", f"/guilds/{guild_id}/channels", token, body), True
    if parent_id and channel.get("parent_id") != parent_id:
        channel = api("PATCH", f"/channels/{channel['id']}", token, {"parent_id": parent_id})
    return channel, False


def ensure_webhook(token, channel):
    hooks = api("GET", f"/channels/{channel['id']}/webhooks", token)
    hook = next((h for h in hooks if h.get("name") == WEBHOOK_NAME), None)
    if not hook:
        hook = api("POST", f"/channels/{channel['id']}/webhooks", token, {"name": WEBHOOK_NAME})
    return f"https://discord.com/api/webhooks/{hook['id']}/{hook['token']}"


def main():
    token = read_token()
    guild_id = find_guild(token)
    existing = {(c["name"], c["type"]): c
                for c in api("GET", f"/guilds/{guild_id}/channels", token)}
    repos, repo_map = discover()

    existing_cfg = {}
    try:
        with open(CONFIG) as fh:
            existing_cfg = json.load(fh)
    except (IOError, ValueError):
        pass
    config = {"guild_id": guild_id, "personas": PERSONAS,
              "default_channel": DEFAULT_CHANNEL, "repoMap": repo_map,
              "avatars": existing_cfg.get("avatars", {}), "channels": {}}

    def add(name, channel, created):
        print(("  + " if created else "  = ") + "#" + name)
        config["channels"][name] = {"channel_id": channel["id"],
                                    "webhook_url": ensure_webhook(token, channel)}

    # Salon système (hors catégorie)
    sys_ch, created = ensure_channel(token, guild_id, existing, DEFAULT_CHANNEL)
    add(DEFAULT_CHANNEL, sys_ch, created)

    # Catégorie "repos"
    category, cat_created = ensure_channel(token, guild_id, existing, REPOS_CATEGORY, ctype=4)
    print(("  + " if cat_created else "  = ") + "catégorie " + REPOS_CATEGORY)

    for name in repos:
        channel, created = ensure_channel(token, guild_id, existing, name, parent_id=category["id"])
        add(name, channel, created)

    os.makedirs(MATRIX_DIR, exist_ok=True)
    with open(CONFIG, "w") as fh:
        json.dump(config, fh, indent=2, ensure_ascii=False)
    os.chmod(CONFIG, 0o600)
    print(f"\nOK -> {CONFIG} ({len(config['channels'])} salons, "
          f"{len(repo_map)} worktrees mappés, {len(PERSONAS)} personas)")


if __name__ == "__main__":
    main()
